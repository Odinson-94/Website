// #region agent log - Ribbon layout verification
(function() {
  const ribbonGroup = document.querySelector('.ribbon-group');
  const ribbonContent = document.querySelector('.ribbon-group-content');
  const btnStack = document.querySelector('.ribbon-btn-stack');
  const formatBtn = document.querySelector('.ribbon-btn[title="Format Painter"]');
  const groupLabel = document.querySelector('.ribbon-group-label');
  
  if (ribbonGroup && ribbonContent && btnStack && formatBtn && groupLabel) {
    const btnStackRect = btnStack.getBoundingClientRect();
    const formatRect = formatBtn.getBoundingClientRect();
    const labelRect = groupLabel.getBoundingClientRect();
    const contentRect = ribbonContent.getBoundingClientRect();
    
    const data = {
      btnStackHeight: btnStackRect.height,
      contentMaxHeight: window.getComputedStyle(ribbonContent).maxHeight,
      formatBottom: formatRect.bottom,
      labelTop: labelRect.top,
      overlap: formatRect.bottom > labelRect.top,
      gap: labelRect.top - formatRect.bottom
    };
    
  }
})();
