        readyPrompt: 'Type <strong>"yes"</strong> or <strong>"proceed"</strong> to generate controls layout'
      }
    };
    
    let view4ActiveConversation = 'drainage';
    let view4IsThinking = false;
    
    // Function to create a thinking container for use with ThinkingAnimation
    // Steps can be strings (legacy) or objects: { text, type: 'think'|'action'|'done', changes?, filename? }
    function createThinkingContainer(thinkingSteps) {
      const container = document.createElement('div');
      container.className = 'thinking-container';
      
      // Build steps list HTML
      let stepsHtml = '';
      thinkingSteps.forEach((step, index) => {
        const isLastStep = index === thinkingSteps.length - 1;
        
        // Support both string format (legacy) and object format (new)
        if (typeof step === 'string') {
          // Legacy string format
          const iconType = isLastStep ? 'check' : 'dot';
          stepsHtml += `<li><span class="step-icon ${iconType}"></span><span class="step-content"><span class="step-text">${step}</span></span></li>`;
        } else {
          // New object format: { text, type, changes?, filename? }
          let iconClass = 'dot';
          let iconChar = '';
          
          if (step.type === 'done') {
            iconClass = 'check';
          } else if (step.type === 'action') {
            iconClass = 'edit';
            iconChar = '✎';
          }
          
          // Build changes HTML if present
          let changesHtml = '';
          if (step.changes) {
            const changeClass = step.changes.startsWith('-') ? 'removed' : 'added';
            changesHtml = `<span class="step-changes"><span class="changes-box"><span class="${changeClass}">${step.changes}</span></span><span class="filename">${step.filename || ''}</span></span>`;
          }
          
          stepsHtml += `<li><span class="step-icon ${iconClass}">${iconChar}</span><span class="step-content"><span class="step-text">${step.text}</span>${changesHtml}</span></li>`;
        }
      });
      
      container.innerHTML = `
        <div class="thinking-header">
          <div class="thinking-header-left">
            <div class="pulsing-node"></div>
            <span class="steps-count">${thinkingSteps.length} steps</span>
          </div>
          <div class="steps-toggle">
            <span class="chevron">⌃</span>
          </div>
        </div>
        <ul class="steps-list">
          ${stepsHtml}
        </ul>
      `;
      
      return container;
    }
    
    // Function to run thinking animation using ThinkingAnimation module
    async function runThinkingSequence(chatContainer, thinkingSteps) {
      // Create and add thinking container
      const thinkingContainer = createThinkingContainer(thinkingSteps);
      chatContainer.appendChild(thinkingContainer);
      chatContainer.scrollTop = chatContainer.scrollHeight;
      
      // Run the animation using ThinkingAnimation module
      return new Promise((resolve) => {
        ThinkingAnimation.run(thinkingContainer, {
          stepDelay: 450,
          autoCollapse: false, // Keep visible after completion
          onComplete: () => {
            chatContainer.scrollTop = chatContainer.scrollHeight;
            resolve(thinkingContainer);
          }
        });
      });
    }
    
    // Function to create a collapsed (completed) thinking container for history
    // Steps can be strings (legacy) or objects: { text, type: 'think'|'action'|'done', changes?, filename? }
    function createCollapsedThinkingContainer(steps) {
      const container = document.createElement('div');
      container.className = 'thinking-container visible';
      
      // Build steps list HTML - all steps already visible (completed state)
      let stepsHtml = '';
      steps.forEach((step, index) => {
        const isLastStep = index === steps.length - 1;
        
        // Support both string format (legacy) and object format (new)
        if (typeof step === 'string') {
          // Legacy string format
          const iconType = isLastStep ? 'check' : 'dot';
          stepsHtml += `<li class="visible"><span class="step-icon ${iconType}"></span><span class="step-content"><span class="step-text">${step}</span></span></li>`;
        } else {
          // New object format: { text, type, changes?, filename? }
          let iconClass = 'dot';
          let iconChar = '';
          
          if (step.type === 'done') {
            iconClass = 'check';
          } else if (step.type === 'action') {
            iconClass = 'edit';
            iconChar = '✎';
          }
          
          // Build changes HTML if present
          let changesHtml = '';
          if (step.changes) {
            const changeClass = step.changes.startsWith('-') ? 'removed' : 'added';
            changesHtml = `<span class="step-changes"><span class="changes-box"><span class="${changeClass}">${step.changes}</span></span><span class="filename">${step.filename || ''}</span></span>`;
          }
          
          stepsHtml += `<li class="visible"><span class="step-icon ${iconClass}">${iconChar}</span><span class="step-content"><span class="step-text">${step.text}</span>${changesHtml}</span></li>`;
        }
      });
      
      container.innerHTML = `
        <div class="thinking-header done">
          <div class="thinking-header-left">
            <div class="pulsing-node"></div>
            <span class="steps-count">${steps.length} steps</span>
          </div>
          <div class="steps-toggle">
            <span class="chevron">⌃</span>
          </div>
        </div>
        <ul class="steps-list">
          ${stepsHtml}
        </ul>
      `;
      
      // Add click handler to toggle expand/collapse
      const header = container.querySelector('.thinking-header');
      const stepsList = container.querySelector('.steps-list');
      const toggle = container.querySelector('.steps-toggle');
      if (header && stepsList) {
        header.addEventListener('click', function() {
          if (toggle) toggle.classList.toggle('expanded');
          stepsList.classList.toggle('expanded');
        });
      }
      
      return container;
    }
    
    // Function to load a conversation into View 4 chat
    function loadView4Conversation(conversationKey) {
      // Get fresh reference to chat messages element (may have been cloned/replaced)
      const chatEl = document.getElementById('chatMessagesIndex4');
      if (!chatEl) {
        console.warn('loadView4Conversation: chatMessagesIndex4 not found');
        return;
      }
      const conversation = view4Conversations[conversationKey];
      if (!conversation) {
        console.warn('loadView4Conversation: conversation not found for key:', conversationKey);
        return;
      }
      
      view4ActiveConversation = conversationKey;
      console.log('Loaded conversation:', conversationKey, '| Active:', view4ActiveConversation);
      
      // Clear current messages
      chatEl.innerHTML = '';
      
      // Add conversation messages
      conversation.messages.forEach(msg => {
        if (msg.type === 'thinking') {
          // Create a collapsed thinking container showing the steps
          const thinkingEl = createCollapsedThinkingContainer(msg.steps);
          chatEl.appendChild(thinkingEl);
        } else {
          // Regular user or bot message
          const msgDiv = document.createElement('div');
          msgDiv.className = msg.type === 'user' ? 'demo-msg-user' : 'demo-msg-bot';
          msgDiv.innerHTML = '<p>' + msg.text + '</p>';
          chatEl.appendChild(msgDiv);
        }
      });
      
      // Add ready prompt
      const promptDiv = document.createElement('div');
      promptDiv.className = 'demo-ready-prompt';
      promptDiv.innerHTML = '<span>' + conversation.readyPrompt + '</span>';
      chatEl.appendChild(promptDiv);
      
      // Scroll to bottom
      chatEl.scrollTop = chatEl.scrollHeight;
      
      // Reset GIF section
      const gifEl = document.getElementById('gifSectionIndex4');
      if (gifEl) {
        const img = gifEl.querySelector('img');
        const placeholder = gifEl.querySelector('.demo-revit-placeholder');
        if (img) img.classList.remove('playing');
        if (placeholder) placeholder.style.display = '';
      }
    }
    
    async function handleView4ChatSend() {
      // Get fresh references to elements
      const inputEl = document.getElementById('chatInputIndex4');
      const chatEl = document.getElementById('chatMessagesIndex4');
      const gifEl = document.getElementById('gifSectionIndex4');
      
      if (!inputEl || !chatEl || view4IsThinking) return;
      const input = inputEl.value.trim().toLowerCase();
      if (!input) return;
      
      // Add user message
      const userMsg = document.createElement('div');
      userMsg.className = 'demo-msg-user';
      userMsg.innerHTML = '<p>' + inputEl.value + '</p>';
      chatEl.appendChild(userMsg);
      inputEl.value = '';
      
      // Remove ready prompt if exists
      const readyPrompt = chatEl.querySelector('.demo-ready-prompt');
      if (readyPrompt) readyPrompt.remove();
      
      // Scroll to bottom
      chatEl.scrollTop = chatEl.scrollHeight;
      
      // Check for proceed commands
      if (input === 'yes' || input === 'proceed' || input === 'y') {
        view4IsThinking = true;
        
        console.log('handleView4ChatSend: Using conversation:', view4ActiveConversation);
        const conversation = view4Conversations[view4ActiveConversation];
        if (!conversation) {
          console.warn('handleView4ChatSend: No conversation found for:', view4ActiveConversation);
          view4IsThinking = false;
          return;
        }
        console.log('Running thinkingSequence:', conversation.thinkingSequence.length, 'steps');
        
        // Run thinking animation using ThinkingAnimation module
        const thinkingContainer = await runThinkingSequence(chatEl, conversation.thinkingSequence);
        
        // Wait a moment then collapse thinking
        await sleep(800);
        if (thinkingContainer && typeof ThinkingAnimation !== 'undefined') {
          await ThinkingAnimation.hide(thinkingContainer);
        }
        
        // Show GIF
        if (gifEl) {
          const img = gifEl.querySelector('img');
          const placeholder = gifEl.querySelector('.demo-revit-placeholder');
          
          if (img && placeholder) {
            placeholder.style.display = 'none';
            
            // Force reload GIF
            const gifSrc = img.src;
            img.src = '';
            img.src = gifSrc;
            
            await sleep(50);
            img.classList.add('playing');
          }
        }
        
        // Add final chat message response
        await sleep(300);
        const botMsg = document.createElement('div');
        botMsg.className = 'demo-msg-bot';
        botMsg.innerHTML = '<p>' + conversation.finalMessage + '</p>';
        chatEl.appendChild(botMsg);
        chatEl.scrollTop = chatEl.scrollHeight;
        
        view4IsThinking = false;
      } else {
        // Unknown command
        await sleep(300);
        const botMsg = document.createElement('div');
        botMsg.className = 'demo-msg-bot';
        botMsg.innerHTML = '<p>Please type "yes" or "proceed" to generate the layout.</p>';
        chatEl.appendChild(botMsg);
        chatEl.scrollTop = chatEl.scrollHeight;
      }
    }
    
    // Use event delegation for send button and input (handles cloned elements)
    document.addEventListener('click', function(e) {
      if (e.target.closest('#chatSendIndex4')) {
        handleView4ChatSend();
      }
    });
    
    document.addEventListener('keydown', function(e) {
      const inputEl = document.getElementById('chatInputIndex4');
      if (e.key === 'Enter' && document.activeElement === inputEl) {
        handleView4ChatSend();
      }
    });
    
    // History item click handlers for View 4 - loads conversation
    // Use event delegation on document for reliability (handles cloned elements)
    document.addEventListener('click', function(e) {
      const historyItem = e.target.closest('#chatHistoryIndex4 .demo-history-item');
      if (!historyItem) return;
      
      console.log('History item clicked:', historyItem);
      
      // Remove active from all, add to clicked
      document.querySelectorAll('#chatHistoryIndex4 .demo-history-item').forEach(i => i.classList.remove('active'));
      historyItem.classList.add('active');
      
      // Load the conversation for this system
      const system = historyItem.getAttribute('data-system') || historyItem.getAttribute('data-conversation');
      console.log('System attribute:', system, '| Exists in conversations:', !!view4Conversations[system]);
      if (system && view4Conversations[system]) {
        loadView4Conversation(system);
      }
    });
    
    // END OF REMOVED VIEW 4 SECTION */
    
    // View 5 buttons (same openChat functionality as View 3)
    const openChatBtnView5 = document.getElementById('openChatBtnView5');
    const tryMoreDemosBtn5 = document.getElementById('tryMoreDemosBtn5');
    if (openChatBtnView5) openChatBtnView5.addEventListener('click', openChat);
    if (tryMoreDemosBtn5) tryMoreDemosBtn5.addEventListener('click', function() {
      window.location.href = 'demos.html';
    });
    
    // --------------------------------------------------
    // VIEW 5: REVIT PLAN CYCLING (click to cycle)
    // --------------------------------------------------
    
    const revitPlanImage = document.getElementById('revitPlanImage');
    
    // Plan images - click to cycle through
    const planImages = ['images/backgrounds/PLAN_A.png', 'images/backgrounds/PLAN_B.png', 'images/backgrounds/PLAN_C.png', 'images/backgrounds/PLAN_D.png'];
    let currentPlanIndex = 0;
    let isRevitPlanAnimating = false;
    
    async function cyclePlans() {
      if (isRevitPlanAnimating) return;
      isRevitPlanAnimating = true;
      
      if (revitPlanImage) {
        revitPlanImage.classList.add('fade-out');
        await sleep(300);
        
        // Cycle to next plan image
        currentPlanIndex = (currentPlanIndex + 1) % planImages.length;
        revitPlanImage.src = planImages[currentPlanIndex];
        
        // Small delay for src to update
        await sleep(50);
        
        // Fade in new plan
        revitPlanImage.classList.remove('fade-out');
      }
      
      await sleep(300);
      isRevitPlanAnimating = false;
    }
    
    // Click on plan image to cycle
    if (revitPlanImage) {
      revitPlanImage.style.cursor = 'pointer';
      revitPlanImage.addEventListener('click', cyclePlans);
    }
    
    // --------------------------------------------------
    // REVIT CONTAINER DRAGGING (via title bar area)
    // --------------------------------------------------
    
    const revitBackgroundEl = document.getElementById('revitBackground');
    const revitDragHandle = document.getElementById('revitDragHandle');
    let isDraggingRevitBg = false;
    let revitBgStartX, revitBgStartY, revitBgInitialX, revitBgInitialY;
    
    if (revitDragHandle) {
      revitDragHandle.addEventListener('mousedown', function(e) {
        isDraggingRevitBg = true;
        revitBgStartX = e.clientX;
        revitBgStartY = e.clientY;
        
        // Get actual pixel position from bounding rect BEFORE adding dragging class
        const rect = revitBackgroundEl.getBoundingClientRect();
        revitBgInitialX = rect.left;
        revitBgInitialY = rect.top;
        
        // Add dragging class to disable CSS transform and transitions
        revitBackgroundEl.classList.add('dragging');
        
        // Set position using the calculated rect values
        revitBackgroundEl.style.left = revitBgInitialX + 'px';
        revitBackgroundEl.style.top = revitBgInitialY + 'px';
      });
    }
    
    document.addEventListener('mousemove', function(e) {
      if (!isDraggingRevitBg) return;
      const deltaX = e.clientX - revitBgStartX;
      const deltaY = e.clientY - revitBgStartY;
      revitBackgroundEl.style.left = (revitBgInitialX + deltaX) + 'px';
      revitBackgroundEl.style.top = (revitBgInitialY + deltaY) + 'px';
    });
    
    document.addEventListener('mouseup', function() {
      if (isDraggingRevitBg) {
        isDraggingRevitBg = false;
        // Keep dragging class to prevent CSS transform from reactivating
        // Don't remove it so the element stays at the user's dragged position
      }
    });
    
    // --------------------------------------------------
    // LEFT RIBA CARD EXPANSION
    // --------------------------------------------------
    // Animation: card moves to center → expands from center (all corners equally) → show content
    
    const ribaPanel = document.getElementById('ribaLeftPanel');
    const ribaBackdrop = document.getElementById('ribaBackdrop');
    
    if (ribaPanel) {
      ribaPanel.addEventListener('wheel', function(e) {
        // Only stop propagation when a card is expanded (to allow scrolling the expanded content)
        // When no card is expanded, let the wheel event bubble up for normal page navigation
        if (expandedClone) {
          e.stopPropagation();
        }
      }, { passive: false });
    }
    
    let expandedClone = null;
    let originalCard = null;
    let cardStartRect = null;
    
    // Expanded size
    const EXPAND_W = 700;
    const EXPAND_H = window.innerHeight * 0.8;
    
    // Center position (where expanded panel will be)
    const getCenterPos = () => ({
      x: window.innerWidth * 0.275 + 40,
      y: window.innerHeight / 2
    });
    
    document.querySelectorAll('.riba-card-left').forEach(card => {
      card.addEventListener('click', function(e) {
        e.stopPropagation();
        
        if (originalCard === this && expandedClone) {
          // Ensure scroll lock is removed when clicking the card again to close
          const ribaPanelUnlock = document.getElementById('ribaLeftPanel');
          if (ribaPanelUnlock) {
            ribaPanelUnlock.classList.remove('scroll-locked');
            ribaPanelUnlock.style.paddingRight = '';
          }
          closeExpandedCard();
          return;
        }
        
        if (expandedClone) {
          closeExpandedCardInstant();
        }
        
        // Record original card dimensions
        const rect = this.getBoundingClientRect();
        cardStartRect = {
          w: rect.width,
          h: rect.height,
          cx: rect.left + rect.width / 2,  // center x
          cy: rect.top + rect.height / 2    // center y
        };
        originalCard = this;
        
        const center = getCenterPos();
        
        // Show backdrop and lock RIBA panel scroll
        if (ribaBackdrop) ribaBackdrop.classList.add('visible');
        const ribaPanelForLock = document.getElementById('ribaLeftPanel');
        if (ribaPanelForLock) {
          // Calculate scrollbar width before hiding it
          const scrollbarWidth = ribaPanelForLock.offsetWidth - ribaPanelForLock.clientWidth;
          // Add compensating padding to prevent content shift
          if (scrollbarWidth > 0) {
            ribaPanelForLock.style.paddingRight = (40 + scrollbarWidth) + 'px'; // 40px is original padding
          }
          ribaPanelForLock.classList.add('scroll-locked');
        }
        
        // Create clone at original position (positioned by center)
        expandedClone = this.cloneNode(true);
        expandedClone.classList.add('riba-clone-expanded');
        // Detect dark mode and use appropriate background
        const isDarkMode = document.documentElement.classList.contains('dark-mode');
        expandedClone.style.cssText = `
          position: fixed;
          width: ${cardStartRect.w}px;
          height: ${cardStartRect.h}px;
          left: ${cardStartRect.cx}px;
          top: ${cardStartRect.cy}px;
          transform: translate(-50%, -50%);
          z-index: 700;
          margin: 0;
          background: ${isDarkMode ? '#2a2a2a' : '#fff'};
        `;
        document.body.appendChild(expandedClone);
        
        // Hide original
        this.style.visibility = 'hidden';
        
        // Force reflow
        expandedClone.offsetHeight;
        
        // STEP 1: Move to center (same size, just position change)
        expandedClone.style.transition = 'left 0.3s ease-out, top 0.3s ease-out, box-shadow 0.3s ease-out';
        expandedClone.style.left = center.x + 'px';
        expandedClone.style.top = center.y + 'px';
        expandedClone.style.boxShadow = '0 12px 40px rgba(0,0,0,0.2)';
        
        setTimeout(() => {
          // STEP 2: Expand from center (width/height grow, center stays fixed due to translate(-50%,-50%))
          expandedClone.style.transition = 'width 0.3s ease-in-out, height 0.3s ease-in-out';
          expandedClone.style.width = EXPAND_W + 'px';
          expandedClone.style.height = EXPAND_H + 'px';
          expandedClone.style.borderColor = 'rgba(0, 160, 160, 0.4)';
          expandedClone.classList.add('expanded');
          
          setTimeout(() => {
            // STEP 3: Show content first, then scrollbar after fade-in
            expandedClone.classList.add('show-content');
            setTimeout(() => {
              expandedClone.classList.add('show-scrollbar');
            }, 200); // Wait for content fade-in
          }, 300);
        }, 300);
        
        expandedClone.addEventListener('click', function(e) {
          e.stopPropagation();
          // Ensure scroll lock is removed when clicking the expanded card to close
          const ribaPanelUnlock = document.getElementById('ribaLeftPanel');
          if (ribaPanelUnlock) {
            ribaPanelUnlock.classList.remove('scroll-locked');
            ribaPanelUnlock.style.paddingRight = '';
          }
          closeExpandedCard();
        });
      });
    });
    
    function closeExpandedCard() {
      // Remove scroll lock immediately so user can scroll right away
      const ribaPanelForUnlock = document.getElementById('ribaLeftPanel');
      if (ribaPanelForUnlock) {
        ribaPanelForUnlock.classList.remove('scroll-locked');
        ribaPanelForUnlock.style.paddingRight = ''; // Reset to CSS default
      }
      
      if (!expandedClone || !originalCard || !cardStartRect) return;
      
      const center = getCenterPos();
      
      // STEP 1: Hide scrollbar first, then content
      expandedClone.classList.remove('show-scrollbar');
      
      setTimeout(() => {
        expandedClone.classList.remove('show-content');
        
        setTimeout(() => {
          // STEP 2: Shrink to original size (center stays fixed)
          expandedClone.classList.remove('expanded');
          expandedClone.style.transition = 'width 0.3s ease-in-out, height 0.3s ease-in-out';
          expandedClone.style.width = cardStartRect.w + 'px';
          expandedClone.style.height = cardStartRect.h + 'px';
          expandedClone.style.borderColor = 'rgba(0,0,0,0.06)';
          
          setTimeout(() => {
            // STEP 3: Move back to original position
            expandedClone.style.transition = 'left 0.3s ease-in, top 0.3s ease-in, box-shadow 0.3s ease-in';
            expandedClone.style.left = cardStartRect.cx + 'px';
            expandedClone.style.top = cardStartRect.cy + 'px';
            expandedClone.style.boxShadow = '0 2px 8px rgba(0,0,0,0.06)';
            
            setTimeout(() => {
              // Cleanup
              if (originalCard) originalCard.style.visibility = '';
              if (expandedClone && expandedClone.parentNode) {
                expandedClone.parentNode.removeChild(expandedClone);
              }
              expandedClone = null;
              originalCard = null;
              cardStartRect = null;
              if (ribaBackdrop) ribaBackdrop.classList.remove('visible');
              const ribaPanelForUnlock = document.getElementById('ribaLeftPanel');
              if (ribaPanelForUnlock) {
                ribaPanelForUnlock.classList.remove('scroll-locked');
                ribaPanelForUnlock.style.paddingRight = '';
              }
            }, 300);
          }, 300);
        }, 150);
      }, 50);
    }
    
    function closeExpandedCardInstant() {
      if (originalCard) originalCard.style.visibility = '';
      if (expandedClone && expandedClone.parentNode) {
        expandedClone.parentNode.removeChild(expandedClone);
      }
      expandedClone = null;
      originalCard = null;
      cardStartRect = null;
      if (ribaBackdrop) ribaBackdrop.classList.remove('visible');
      const ribaPanelForUnlock = document.getElementById('ribaLeftPanel');
      if (ribaPanelForUnlock) {
        ribaPanelForUnlock.classList.remove('scroll-locked');
        ribaPanelForUnlock.style.paddingRight = '';
      }
    }
    
    // Close when clicking backdrop
    if (ribaBackdrop) {
      ribaBackdrop.addEventListener('click', function(e) {
        e.stopPropagation();
        closeExpandedCard();
      });
    }
    
    // Close when clicking anywhere outside the expanded card
    document.addEventListener('click', function(e) {
      if (!expandedClone) return;
      
      // If clicked on the expanded clone itself, don't close (clone has its own handler)
      if (expandedClone.contains(e.target)) return;
      
      // If clicked on the original card or another RIBA card, don't close here
      if (e.target.closest('.riba-card-left')) return;
      
      // Close the card when clicking anywhere else
      closeExpandedCard();
    });
    
    // --------------------------------------------------
    // VIEW 4 AUTO SIGNAL FIRING + QUESTIONS
    // --------------------------------------------------
    // When on View 4, nodes fire signals automatically (1-2 per second)
    // Questions appear from non-MEP parties when signals fire/arrive
    // Stops on hover, stops permanently on project complete
    
    const nodeQuestions = {
      'Project Manager': [
        "Is Stage 4 on programme?",
        "When can we issue tender?",
        "Are there any design risks?",
        "What's holding up coordination?",
        "Have you logged this change?",
        "Is the cost plan updated?",
        "Can we accelerate this?",
        "Who's responsible for this delay?",
        "Are all RFIs closed out?",
        "What's the critical path item?",
        "Have you updated the tracker?",
        "Is the client aware of this?"
      ],
      'Architect': [
        "Where are the MEP layouts?",
        "Does the plant room fit?",
        "Can we move this riser?",
        "What's the ceiling void depth?",
        "Is there coordination with structure?",
        "When will sections be ready?",
        "Have clashes been resolved?",
        "What's the services zone?",
        "Can you check the plantroom access?",
        "Are penetrations coordinated?",
        "What's the bulkhead requirement?",
        "Is fire compartmentation clear?"
      ],
      'Client': [
        "Does this comply with brief?",
        "What's the energy strategy?",
        "Is this within budget?",
        "Can we see a 3D visual?",
        "What are the running costs?",
        "Is BREEAM achievable?",
        "Have you met with the operator?",
        "What's the maintenance access like?",
        "Can we reduce the plant space?",
        "Is there expansion capacity?",
        "What's the sustainability score?",
        "Have planning conditions been met?"
      ],
      'Contractor': [
        "We need drawings on site now!",
        "Can you issue for construction?",
        "Is the spec finalised?",
        "When is equipment arriving?",
        "Have you approved the submittals?",
        "Need RFI response urgently",
        "Are procurement lists ready?",
        "What's the lead time on chillers?",
        "Can we proceed with this route?",
        "Is this change approved?",
        "Need updated programme info",
        "Where's the builders work?"
      ],
      'Structural Engineer': [
        "What's the plant loading?",
        "Where are the major penetrations?",
        "Can this beam be moved?",
        "What are the hanger loads?",
        "Is the rooftop plant confirmed?",
        "Do we have padstone requirements?",
        "What's the tank room loading?",
        "Are there any embedded services?",
        "What's the UPS room load?",
        "Need penetration locations ASAP",
        "Can you confirm floor loadings?",
        "Have you coordinated with rebar?"
      ]
    };
    
    let questionIndices = {};
    Object.keys(nodeQuestions).forEach(k => questionIndices[k] = 0);
    
    let autoSignalInterval = null;
    let autoSignalPaused = false;
    let projectComplete = false;
    
    // Track which nodes are auto-signal sources (so we know when their pulses arrive)
    const autoSignalSources = new Set();
    
    // Get a question for a party (cycles through)
    function getNextQuestion(partyTitle) {
      const questions = nodeQuestions[partyTitle];
      if (!questions) return null;
      const idx = questionIndices[partyTitle] || 0;
      questionIndices[partyTitle] = (idx + 1) % questions.length;
      return questions[idx];
    }
    
    // Show QUESTION on a node (grey text, for auto-signals only)
    function flashQuestionOnNode(brainNodeId) {
      if (currentOverlayView !== 4 || projectComplete) return;
      
      const nodeData = overlayNodeData.find(nd => nd.nodeId === brainNodeId);
      if (!nodeData) return;
      
      // Only non-MEP parties show questions
      if (nodeData.isMEPEngineer) return;
      
      const codeEl = nodeData.element.querySelector('.node-code');
      if (!codeEl) return;
      
      const text = getNextQuestion(nodeData.title);
      if (!text) return;
      
      codeEl.textContent = text;
      codeEl.style.color = '#888'; // Grey for questions
      codeEl.classList.add('visible');
      
      setTimeout(() => {
        codeEl.classList.remove('visible');
      }, 1200); // Longer display for questions
    }
    
    // Fire signal from a random visible node (auto-signal mode)
    function fireAutoSignal() {
      if (autoSignalPaused || projectComplete || currentOverlayView !== 4) return;
      if (!overlayNodeData.length) return;
      
      // Pick a random non-MEP overlay node
      const nonMEPNodes = overlayNodeData.filter(nd => !nd.isMEPEngineer);
      if (!nonMEPNodes.length) return;
      
      const randomNode = nonMEPNodes[Math.floor(Math.random() * nonMEPNodes.length)];
      
      // Track this as an auto-signal source
      autoSignalSources.add(randomNode.nodeId);
      
      // Clear from set after 3 seconds (enough time for pulses to arrive)
      setTimeout(() => {
        autoSignalSources.delete(randomNode.nodeId);
      }, 3000);
      
      // Show question on the firing node immediately
      flashQuestionOnNode(randomNode.nodeId);
      
      // Trigger pulse from brain.js (pulses will trigger onPulseArrived when they land)
      if (window.triggerNodePulse) {
        window.triggerNodePulse(randomNode.nodeId);
      }
    }
    
    // Start auto signal firing for View 4
    function startAutoSignals() {
      if (autoSignalInterval || projectComplete) return;
      
      // Fire 1-2 signals per second
      autoSignalInterval = setInterval(() => {
        fireAutoSignal();
        // Sometimes fire a second one
        if (Math.random() > 0.5) {
          setTimeout(fireAutoSignal, 400);
        }
      }, 1000);
    }
    
    // Stop auto signal firing
    function stopAutoSignals() {
      if (autoSignalInterval) {
        clearInterval(autoSignalInterval);
        autoSignalInterval = null;
      }
      autoSignalSources.clear();
    }
    
    // Set project complete (stops questions permanently)
    function setProjectComplete() {
      projectComplete = true;
      stopAutoSignals();
      // Clear all code displays
      overlayNodeData.forEach(nodeData => {
        const codeEl = nodeData.element.querySelector('.node-code');
        if (codeEl) codeEl.classList.remove('visible');
      });
    }
    window.setProjectComplete = setProjectComplete;
    
    // Pulse callbacks:
    // - HOVER triggers codes (original behavior)
    // - AUTO-SIGNAL triggers questions (grey) on receiving nodes
    
    window.onPulseFired = function(nodeId) {
      if (!pulseCodeFlashEnabled || currentOverlayView !== 4) return;
      
      // Auto-signal firing is handled in fireAutoSignal() directly
      // This callback only handles hover-triggered pulses
      if (!autoSignalSources.has(nodeId)) {
        // User hover: show code (original behavior)
        flashCodeOnNodeById(nodeId);
      }
      // If it's an auto-signal source, question was already shown in fireAutoSignal()
    };
    
    window.onPulseArrived = function(toNodeIdx, sourceNodeId) {
      if (!pulseCodeFlashEnabled || currentOverlayView !== 4) return;
      
      // Check if this pulse came from an auto-signal source
      if (autoSignalSources.has(sourceNodeId) && !projectComplete) {
        // Auto-signal: show question on receiving node (grey)
        flashQuestionOnNode(toNodeIdx);
      } else {
        // User hover: show code (original behavior)
        flashCodeOnNodeById(toNodeIdx);
      }
    };
    
    // Pause auto-signals on hover over brain (but don't stop existing pulses)
    const brainCanvasForSignals = document.getElementById('brainCanvas');
    if (brainCanvasForSignals) {
      brainCanvasForSignals.addEventListener('mouseenter', () => {
        autoSignalPaused = true;
      });
      
      brainCanvasForSignals.addEventListener('mouseleave', () => {
        autoSignalPaused = false;
      });
    }
    
    // Export for view controller
    window.startAutoSignals = startAutoSignals;
    window.stopAutoSignals = stopAutoSignals;
    
    // Start the main animation
    runMainAnimation();
  });
