  // --------------------------------------------------
  // View Controller
  // --------------------------------------------------
  // Controls view transitions for the neural network visualization.
  // Uses targetViewIndex pattern to prevent text bleeding during fast scrolling.
  // All animations delegate to brain.js animateToViewState() function.
  
  if (window.PERF) window.PERF.mark('view-controller.js START');
  
  document.addEventListener('DOMContentLoaded', function() {
    if (window.PERF) window.PERF.mark('DOMContentLoaded fired');
    // #region agent log
    setTimeout(() => {
      const heroContainer = document.getElementById('heroTextContainer');
      const heroInner = heroContainer?.querySelector('.hero-text-inner');
      const heroHeading = heroContainer?.querySelector('.hero-heading');
      const heroSubheading = heroContainer?.querySelector('.hero-subheading');
      const containerStyles = heroContainer ? getComputedStyle(heroContainer) : null;
      const innerStyles = heroInner ? getComputedStyle(heroInner) : null;
      const headingStyles = heroHeading ? getComputedStyle(heroHeading) : null;
      const subheadingStyles = heroSubheading ? getComputedStyle(heroSubheading) : null;
      fetch('http://127.0.0.1:7242/ingest/31da8b6e-d83f-42fc-b222-794ab77bafe7',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'view-controller.js:DOMContentLoaded',message:'Hero text computed styles',data:{containerWidth:containerStyles?.width,containerMaxWidth:containerStyles?.maxWidth,containerHeight:containerStyles?.height,innerWidth:innerStyles?.width,innerMaxWidth:innerStyles?.maxWidth,headingFontSize:headingStyles?.fontSize,headingLineHeight:headingStyles?.lineHeight,headingHeight:headingStyles?.height,subheadingFontSize:subheadingStyles?.fontSize,subheadingLineHeight:subheadingStyles?.lineHeight},timestamp:Date.now(),sessionId:'debug-session',hypothesisId:'A,B,C,D'})}).catch(()=>{});
    }, 500);
    // #endregion
    const rightPanel = document.getElementById('rightPanel');
    const logo = document.getElementById('logo');
    const menubar = document.getElementById('menubar');
    const scrollIndicator = document.getElementById('scrollIndicator');
    const darkToggle = document.getElementById('darkToggle');
    const toggleSwitch = document.getElementById('toggleSwitch');
    const sectionIndicator = document.getElementById('sectionIndicator');
    const sectionDots = document.querySelectorAll('.section-dot');
    
    // --------------------------------------------------
    // TARGET VIEW TRACKING
    // --------------------------------------------------
    // targetViewIndex is the single source of truth for which view
    // we're navigating to. Text/panels only show when animation completes
    // AND targetViewIndex still matches. This prevents text bleeding.
    
    let targetViewIndex = 0;
    let currentView = 0;  // Last confirmed view (after animation complete)
    
    function setTargetView(viewNum) {
      targetViewIndex = viewNum;
      // Also update brain.js target
      if (window.setTargetView) {
        window.setTargetView(viewNum);
      }
    }
    
    function isTargetView(viewNum) {
      return targetViewIndex === viewNum;
    }
    
    // --------------------------------------------------
    // ANIMATION DURATIONS (from brain.js)
    // --------------------------------------------------
    // These match the durations in brain.js ANIMATION_DURATIONS
    // Using functions to get them ensures they stay in sync
    
    function getDuration(type) {
      if (window.ANIMATION_DURATIONS) {
        return window.ANIMATION_DURATIONS[type] || 800;
      }
      // Fallback values if brain.js not loaded
      const defaults = {
        panOnly: 800,
        zoomWithPan: 1000,
        brainMove: 600,
        textDelay: 400
      };
      return defaults[type] || 800;
    }
    
    // --------------------------------------------------
    // LOCK FLAGS (COMMENTED OUT - using targetViewIndex instead)
    // --------------------------------------------------
    // These were used to prevent navigation until content appeared.
    // Now we use targetViewIndex pattern: text only shows when
    // animation completes AND target hasn't changed.
    
    // let view1Ready = false;        // REMOVED - use targetViewIndex
    // let view2CanScrollDown = false; // REMOVED - use targetViewIndex
    // let view3Ready = false;        // REMOVED - use targetViewIndex
    // let view4Ready = false;        // REMOVED - use targetViewIndex
    // let view5Ready = false;        // REMOVED - use targetViewIndex
    // let view6Ready = false;        // REMOVED - use targetViewIndex
    // let view7Ready = false;        // REMOVED - use targetViewIndex
    
    let isTransitioning = false;  // Still needed to prevent overlapping animations
    let view3AnimationComplete = true; // Animation removed - always ready
    let isZoomedIn = false;
    
    // --------------------------------------------------
    // VIEW 3 VIDEO CONTROL
    // --------------------------------------------------
    // Video only plays when on View 3. Stops when fully leaving View 3.
    
    function playView3Video() {
      const video = document.getElementById('demoIntroVideo');
      if (video) {
        // Ensure loop is always enabled
        video.loop = true;
        // Resume from current position (don't reset)
        video.play().catch(() => {});
        // #region agent log
        fetch('http://127.0.0.1:7242/ingest/31da8b6e-d83f-42fc-b222-794ab77bafe7',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'view-controller.js:playView3Video',message:'Video play called (resume)',data:{currentTime:video.currentTime,paused:video.paused,readyState:video.readyState},timestamp:Date.now(),sessionId:'debug-session',hypothesisId:'B'})}).catch(()=>{});
        // #endregion
      }
    }
    
    // Ensure intro video is ALWAYS playing when on View 3
    (function() {
      const video = document.getElementById('demoIntroVideo');
      if (video) {
        // Fallback loop - restart if video ends
        video.addEventListener('ended', function() {
          video.currentTime = 0;
          video.play().catch(() => {});
        });
        
        // Check every 500ms if video should be playing but isn't
        setInterval(function() {
          if (currentView === 3 && video.paused && video.readyState >= 2) {
            video.play().catch(() => {});
          }
        }, 500);
        
        // Also restart on visibility change (tab switching, etc.)
        document.addEventListener('visibilitychange', function() {
          if (!document.hidden && currentView === 3 && video.paused) {
            video.play().catch(() => {});
          }
        });
      }
    })();
    
    function stopView3Video() {
      const video = document.getElementById('demoIntroVideo');
      if (video) {
        video.pause();
        // #region agent log
        fetch('http://127.0.0.1:7242/ingest/31da8b6e-d83f-42fc-b222-794ab77bafe7',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'view-controller.js:stopView3Video',message:'Video pause called',data:{currentTime:video.currentTime,paused:video.paused},timestamp:Date.now(),sessionId:'debug-session',hypothesisId:'C'})}).catch(()=>{});
        // #endregion
      }
    }
    
    // --------------------------------------------------
    // AUTO-HOVER NODE CYCLING (Views 1 & 8)
    // --------------------------------------------------
    // Automatically cycles through brain regions, hovering the center node
    // of each region for 3-4 seconds. Only active on views 1 and 8.
    
    let autoHoverInterval = null;
    let autoHoverRegionIndex = 0;
    const AUTO_HOVER_DURATION = 3000; // 3 seconds per region
    const BRAIN_REGIONS = [0, 1, 2, 3, 4]; // Frontal, Parietal, Occipital, Temporal, Central
    let activeAutoHovers = []; // Track multiple active hovers for overlap
    
    function startAutoHover() {
      if (autoHoverInterval) return; // Already running
      
      // Initial hover
      triggerAutoHover();
      
      // Cycle through regions with overlap
      autoHoverInterval = setInterval(() => {
        autoHoverRegionIndex = (autoHoverRegionIndex + 1) % BRAIN_REGIONS.length;
        triggerAutoHover();
      }, AUTO_HOVER_DURATION);
    }
    
    function stopAutoHover() {
      if (autoHoverInterval) {
        clearInterval(autoHoverInterval);
        autoHoverInterval = null;
      }
      // Clear all active hover timeouts
      activeAutoHovers.forEach(timeout => clearTimeout(timeout));
      activeAutoHovers = [];
      // Pass false to indicate this is auto-hover cleanup, not user action
      if (window.clearHoveredNode) {
        window.clearHoveredNode(false);
      }
    }
    
    function triggerAutoHover() {
      if (!window.getCenterNodeInRegion || !window.setHoveredNode) return;
      
      // Don't auto-hover if user is manually hovering
      if (window.isUserHovering && window.isUserHovering()) return;
      
      const regionNum = BRAIN_REGIONS[autoHoverRegionIndex];
      const nodeId = window.getCenterNodeInRegion(regionNum);
      
      if (nodeId !== null) {
        // Set the new hover (overlaps with previous which fades naturally)
        // Pass false to indicate this is auto-hover, not user-initiated
        window.setHoveredNode(nodeId, false);
      }
    }
    
    // Check if auto-hover should be active based on current view
    function updateAutoHover(viewNum) {
      if (viewNum === 0 || viewNum === 1 || viewNum === 8) {
        startAutoHover();
      } else {
        stopAutoHover();
      }
    }
    
    // Animated section indicator with trailing ball
    const activeBall = document.getElementById('sectionActiveBall');
    const trailBall1 = document.getElementById('trailBall1');
    const trailBall2 = document.getElementById('trailBall2');
    let previousDotTop = 0;
    
    // --------------------------------------------------
    // SECTION INDICATOR (Dots on left side)
    // --------------------------------------------------
    // Shows current view with animated ball. View 0 has no dot.
    
    function updateSectionIndicator(viewNum) {
      const targetDot = document.querySelector(`.section-dot[data-view="${viewNum}"]`);
      if (!targetDot) return;
      
      // Calculate target position
      const targetTop = targetDot.offsetTop;
      const startTop = previousDotTop;
      
      // Update active class on dots
      sectionDots.forEach(dot => {
        const dotView = parseInt(dot.getAttribute('data-view'));
        if (dotView === viewNum) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
      
      // Create trail effect - position trail balls at start
      if (Math.abs(targetTop - startTop) > 5) {
        trailBall1.style.top = startTop + 'px';
        trailBall2.style.top = startTop + 'px';
        
        // Reset and trigger animation
        trailBall1.classList.remove('animating');
        trailBall2.classList.remove('animating');
        trailBall1.offsetHeight; // Force reflow
        trailBall1.classList.add('animating');
        setTimeout(() => trailBall2.classList.add('animating'), 30);
      }
      
      // Animate the active ball immediately
      activeBall.style.top = targetTop + 'px';
      previousDotTop = targetTop;
    }
    
    // Initialize ball position on first dot (View 0)
    setTimeout(() => {
      const firstDot = document.querySelector('.section-dot[data-view="0"]');
      if (firstDot && activeBall) {
        previousDotTop = firstDot.offsetTop;
        activeBall.style.top = previousDotTop + 'px';
      }
    }, 100);
    
    // --------------------------------------------------
    // SECTION DOT CLICK HANDLERS
    // --------------------------------------------------
    // Clicking a dot navigates to that view immediately.
    // Ball animation happens instantly, view transition follows.
    
    sectionDots.forEach(dot => {
      dot.addEventListener('click', async () => {
        const targetView = parseInt(dot.getAttribute('data-view'));
        
        // Validate target (12 views: 0-11)
        if (targetView < 0 || targetView > 11) return;
        
        // During content loading phase - block completely
        if (isTransitioning && !animationPhase) {
          console.log('Dot click blocked - content loading phase');
          return;
        }
        
        // Same view we're already going to - ignore
        if (targetViewIndex === targetView) return;
        
        // IMMEDIATE: Update ball position (don't wait for view transition)
        updateSectionIndicator(targetView);
        
        // Navigate to target view (can interrupt animation phase)
        await navigateToView(targetView);
      });
    });
    
    // --------------------------------------------------
    // UNIFIED NAVIGATION FUNCTION
    // --------------------------------------------------
    // This is the SINGLE function for navigating between views.
    // It handles all transitions using animateToViewState().
    // Text/panels only appear after animation completes AND target matches.
    
    // --------------------------------------------------
    // INTERRUPTIBLE ANIMATION SYSTEM
    // --------------------------------------------------
    // Animation phase: camera/zoom transitions - CAN be interrupted
    // Content phase: text/panel loading - CANNOT be interrupted
    // When interrupted, new animation starts from current position (smooth handoff)
    
    let animationPhase = false;  // true = interruptible, false = locked
    
    async function navigateToView(targetView) {
      // During content loading phase - block completely
      if (isTransitioning && !animationPhase) {
        console.log('Navigation blocked - content loading phase');
        return;
      }
      
      // Already navigating to this view - ignore
      if (isTransitioning && targetViewIndex === targetView) {
        console.log('Already navigating to view', targetView);
        return;
      }
      
      // Same view and not transitioning - ignore
      if (currentView === targetView && !isTransitioning) return;
      
      // If interrupting an animation, log it
      if (isTransitioning && animationPhase) {
        console.log(`Interrupting animation to go to view ${targetView}`);
        // The previous animation will continue but exit at target check
        // New animation will start from current positions (smooth handoff)
      }
      
      isTransitioning = true;
      animationPhase = true;  // Enter interruptible phase
      const startView = currentView;
      
      // #region agent log
      const videoEl = document.getElementById('demoIntroVideo');
      fetch('http://127.0.0.1:7242/ingest/31da8b6e-d83f-42fc-b222-794ab77bafe7',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'view-controller.js:navigateToView:start',message:'Navigation started',data:{startView:startView,targetView:targetView,videoPlaying:videoEl?!videoEl.paused:null,videoTime:videoEl?.currentTime},timestamp:Date.now(),sessionId:'debug-session',hypothesisId:'D'})}).catch(()=>{});
      // #endregion
      
      // Set target immediately - this is checked when animations complete
      setTargetView(targetView);
      updateSectionIndicator(targetView);
      
      // Hide scroll indicator during transition
      scrollIndicator.classList.remove('visible');
      
      // IMMEDIATELY hide back-to-top if going to views 0 or 1
      if (targetView <= 1) {
        backToTop.classList.remove('visible');
      }
      
      // IMMEDIATELY hide all text content - prevents bleeding
      hideAllPanels();
      // Always hide rightPanel at start of navigation
      // (will be re-shown below if going to View 1, or in showViewContent for View 2)
      rightPanel.classList.remove('visible');
      
      // Ensure core UI elements are visible (in case interrupted during intro)
      logo.classList.add('visible');
      menubar.classList.add('visible');
      sectionIndicator.classList.add('visible');
      darkToggle.classList.add('visible');
      
      // Start neural animations if not already started (in case interrupted early)
      if (window.startNeuralAnimations) {
        window.startNeuralAnimations();
      }
      
      console.log(`navigateToView: ${startView} -> ${targetView}`);
      
      // Calculate duration based on transition type
      const startState = window.VIEW_STATES ? window.VIEW_STATES[startView] : null;
      const targetState = window.VIEW_STATES ? window.VIEW_STATES[targetView] : null;
      const zoomChanging = startState && targetState && Math.abs(startState.zoom - targetState.zoom) > 0.5;
      const duration = zoomChanging ? getDuration('zoomWithPan') : getDuration('panOnly');
      
      // Special handling for View 1 (hero text and rightPanel visibility)
      // IMPORTANT: Always set state based on TARGET, not conditionally on startView
      // This handles interruption correctly (when currentView is stale)
      const heroTextContainer = document.getElementById('heroTextContainer');
      if (targetView === 1) {
        // Going TO View 1 - show hero text and rightPanel
        heroTextContainer.classList.remove('fade-out');
        heroTextContainer.classList.add('visible');
        rightPanel.classList.add('visible');
        document.getElementById('thinkingSection').classList.remove('visible');
        resetView2Content();
        // #region agent log
        setTimeout(() => {
          const heroInner = heroTextContainer.querySelector('.hero-text-inner');
          const heroHeading = heroTextContainer.querySelector('.hero-heading');
          const containerStyles = getComputedStyle(heroTextContainer);
          const innerStyles = heroInner ? getComputedStyle(heroInner) : null;
          const headingStyles = heroHeading ? getComputedStyle(heroHeading) : null;
          fetch('http://127.0.0.1:7242/ingest/31da8b6e-d83f-42fc-b222-794ab77bafe7',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'view-controller.js:navigateToView1',message:'View1 hero styles when visible',data:{containerClasses:heroTextContainer.className,containerWidth:containerStyles.width,containerLeft:containerStyles.left,innerMaxWidth:innerStyles?.maxWidth,headingFontSize:headingStyles?.fontSize,headingHeight:headingStyles?.height,windowWidth:window.innerWidth},timestamp:Date.now(),sessionId:'debug-session',hypothesisId:'A,B'})}).catch(()=>{});
        }, 100);
        // #endregion
      } else {
        // Going to ANY other view - always hide hero text
        heroTextContainer.classList.remove('visible');
        heroTextContainer.classList.add('fade-out');
        // rightPanel already removed above
      }
      
      // Animate brain to target view
      // animateToViewState reads CURRENT values, so interruption works naturally
      if (window.animateToViewState) {
        await window.animateToViewState(targetView);
      } else {
        // Fallback if animateToViewState not available
        await sleep(duration);
      }
      
      // Check if we were interrupted (target changed during animation)
      if (!isTargetView(targetView)) {
        console.log('Animation interrupted, yielding to new navigation');
        // Don't reset isTransitioning - the interrupting navigation owns it now
        return;
      }
      
      // ========== ENTER CONTENT PHASE - NO MORE INTERRUPTS ==========
      animationPhase = false;
      
      // Wait a beat before showing content
      await sleep(getDuration('textDelay'));
      
      // Final check - target might have changed during delay
      if (!isTargetView(targetView)) {
        console.log('Target changed during delay, skipping content show');
        isTransitioning = false;
        return;
      }
      
      // Update current view and show content
      const previousView = currentView;
      currentView = targetView;
      isZoomedIn = (targetView >= 2 && targetView <= 7);
      
      // Stop View 3 video only when COMPLETELY leaving View 3
      if (previousView === 3 && targetView !== 3) {
        stopView3Video();
        // #region agent log
        fetch('http://127.0.0.1:7242/ingest/31da8b6e-d83f-42fc-b222-794ab77bafe7',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'view-controller.js:navigateToView',message:'Leaving View 3 completely',data:{previousView:previousView,targetView:targetView,isTransitioning:isTransitioning},timestamp:Date.now(),sessionId:'debug-session',hypothesisId:'C'})}).catch(()=>{});
        // #endregion
      }
      
      // Show appropriate content for target view
      showViewContent(targetView);
      
      // Hide scroll indicator on View 11 (BUILD X - last view)
      if (targetView === 11) {
        scrollIndicator.classList.remove('visible');
        updateBackToTop();
      } else {
        scrollIndicator.classList.add('visible');
        updateBackToTop();
      }
      isTransitioning = false;
    }
    
    // --------------------------------------------------
    // SHOW VIEW CONTENT
    // --------------------------------------------------
    // Shows the text/panels for a specific view.
    // Only called after animation completes AND target matches.
    
    function showViewContent(viewNum) {
      // Show/hide section indicator based on view
      if (viewNum === 9) {
        sectionIndicator.classList.remove('visible');
      } else {
        sectionIndicator.classList.add('visible');
      }
      
      // Update auto-hover based on view (active on views 1 and 8)
      updateAutoHover(viewNum);
      
      // Overlay nodes disabled during demo consolidation
      // TODO: Re-enable when overlay node views are added back
      // if (viewNum === 4) {
      //   showOverlayNodes(viewNum);
      // } else {
      //   hideOverlayNodes();
      // }
      hideOverlayNodes();
      
      switch(viewNum) {
        case 0:
          // View 0: Brain centered, no panels (or add view0PanelBg if needed)
          break;
          
        case 1:
          // View 1: Hero text on right, no panels
          break;
          
        case 2:
          // View 2: Right panel with services + RIBA left panel
          rightPanel.classList.add('visible');
          document.getElementById('thinkingSection').classList.add('visible');
          // Show RIBA stages on LEFT side
          const ribaLeftPanel = document.getElementById('ribaLeftPanel');
          if (ribaLeftPanel) ribaLeftPanel.classList.add('visible');
          // Show services content immediately (thinking animation removed)
          showView2ContentInstantly();
          // #region agent log
          setTimeout(() => {
            const thinkingSection = document.getElementById('thinkingSection');
            const solutionSection = document.getElementById('ourSolutionSection');
            const solutionHeading = solutionSection?.querySelector('.solution-heading');
            const bodyText = solutionSection?.querySelector('.about-us-text');
            const thinkingStyles = thinkingSection ? getComputedStyle(thinkingSection) : null;
            const sectionStyles = solutionSection ? getComputedStyle(solutionSection) : null;
            const headingStyles = solutionHeading ? getComputedStyle(solutionHeading) : null;
            const bodyStyles = bodyText ? getComputedStyle(bodyText) : null;
            fetch('http://127.0.0.1:7242/ingest/31da8b6e-d83f-42fc-b222-794ab77bafe7',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({location:'view-controller.js:View2',message:'AEC Package section styles',data:{thinkingMaxWidth:thinkingStyles?.maxWidth,thinkingWidth:thinkingStyles?.width,sectionMaxWidth:sectionStyles?.maxWidth,sectionWidth:sectionStyles?.width,headingFontSize:headingStyles?.fontSize,headingWidth:headingStyles?.width,bodyMaxWidth:bodyStyles?.maxWidth,bodyWidth:bodyStyles?.width,bodyClassName:bodyText?.className},timestamp:Date.now(),sessionId:'debug-session',hypothesisId:'AEC'})}).catch(()=>{});
          }, 100);
          // #endregion
          break;
          
        case 3:
          // View 3: Demo Intro (40/60 split with image)
          const demoIntroOverlay = document.getElementById('demoIntroOverlay');
          if (demoIntroOverlay) demoIntroOverlay.classList.add('visible');
          // Play video when entering View 3
          playView3Video();
          break;
          
        case 4:
          // View 4: MEP Floorplan Demo (chat + Revit)
          const gifOverlayEl = document.getElementById('gifOverlay');
          if (gifOverlayEl) gifOverlayEl.classList.add('visible');
          break;
          
        case 5:
          // View 5: Schematics MEP Demo
          const schematicsOverlay = document.getElementById('schematicsOverlay');
          if (schematicsOverlay) schematicsOverlay.classList.add('visible');
          break;
          
        case 6:
          // View 6: 3D Modelling MEP Demo
          const modellingOverlay = document.getElementById('modellingOverlay');
          if (modellingOverlay) modellingOverlay.classList.add('visible');
          break;
          
        case 7:
          // View 7: Schedules MEP Demo
          const schedulesOverlay = document.getElementById('schedulesOverlay');
          if (schedulesOverlay) schedulesOverlay.classList.add('visible');
          break;
          
        case 8:
          // View 8: Spec Writing MEP Demo
          const specWritingOverlay = document.getElementById('specWritingOverlay');
          if (specWritingOverlay) specWritingOverlay.classList.add('visible');
          break;
          
        case 9:
          // View 9: Architectural Build Demo
          const archBuildOverlay = document.getElementById('archBuildOverlay');
          if (archBuildOverlay) archBuildOverlay.classList.add('visible');
          break;
          
        case 10:
          // View 10: Coming Soon (Structural & Civil)
          const comingSoonOverlay = document.getElementById('comingSoonOverlay');
          if (comingSoonOverlay) comingSoonOverlay.classList.add('visible');
          break;
          
        case 11:
          // View 11: BUILD X Demo (footer embedded at bottom)
          const buildXOverlay = document.getElementById('buildXOverlay');
          if (buildXOverlay) buildXOverlay.classList.add('visible');
          // Add dark mode for menubar (uses existing html.dark-mode styles from shared-styles.css)
          document.documentElement.classList.add('dark-mode');
          document.body.classList.add('view-dark-header');
          break;
      }
    }
    
    // --------------------------------------------------
    // OVERLAY NODES - Interactive nodes over brain
    // --------------------------------------------------
    // Shows 5 clickable nodes anchored to brain nodes
    // Hovering triggers the actual brain node hover behavior
    // After 1 second hover, loading ring appears with accelerating pulses
    
    const RING_DURATION = 3000; // Duration of loading ring in ms - change this to adjust all timings
    
    const overlayContainer = document.getElementById('overlayNodesContainer');
    let overlayNodeData = []; // {element, nodeId, hoverTimer, loadingState}
    let overlayAnimationFrame = null;
    let overlayActive = false;
    let currentOverlayView = null;
    
    function showOverlayNodes(viewNum) {
      if (!window.getCenterNodesForView) {
        console.log('getCenterNodesForView not available');
        return;
      }
      
      // Get 6 nodes closest to center, spread out
      const centerNodes = window.getCenterNodesForView(viewNum, 8);
      if (!centerNodes.length) {
        console.log('No center nodes found for view', viewNum);
        return;
      }
      
      currentOverlayView = viewNum;
      
      // Node titles for MEP screen (View 4) only
      const nodeTitles = [
        'MEP Engineer',
        'Project Manager',
        'Architect', 
        'Structural Engineer',
        'Client',
        'Contractor',
        'Building Control',
        'Civil Engineer'
      ];
      
      // Clear existing overlay nodes
      overlayContainer.innerHTML = '';
      overlayNodeData = [];
      
      // Create overlay node for each
      centerNodes.forEach((nodeInfo, index) => {
        const overlayNode = document.createElement('div');
        overlayNode.className = 'overlay-node';
        overlayNode.dataset.nodeId = nodeInfo.node.id;
        
        const title = nodeTitles[index % nodeTitles.length];
        const isMEPEngineer = (index === 0);
        
        // Only show titles on View 4 (MEP screen)
        const showTitleClass = (viewNum === 4) ? ' show-title' : '';
        const showHintClass = (viewNum === 4 && isMEPEngineer) ? ' show-hint' : '';
        const mepShineClass = (viewNum === 4 && isMEPEngineer) ? ' mep-shine' : '';
        
        overlayNode.className = 'overlay-node' + showTitleClass + showHintClass + mepShineClass;
        overlayNode.dataset.nodeId = nodeInfo.node.id;
        
        overlayNode.innerHTML = `
          <div class="node-title">${title}</div>
          ${isMEPEngineer && viewNum === 4 ? '<div class="node-arrow">↑</div><div class="node-hint">hover here</div>' : ''}
          <div class="node-code"></div>
          <div class="node-core"></div>
          <div class="node-glow"></div>
          <div class="node-pulse-ring"></div>
          <svg class="loading-ring" viewBox="0 0 32 32">
            <circle cx="16" cy="16" r="14"></circle>
          </svg>
        `;
        
        const nodeData = {
          element: overlayNode,
          nodeId: nodeInfo.node.id,
          hoverTimer: null,
          loadingState: 'idle', // idle, loading, accelerating, loaded
          accelerateInterval: null,
          codeInterval: null,
          title: title,
          isMEPEngineer: isMEPEngineer
        };
        
        // Hover handlers - trigger actual brain node hover + loading sequence
        overlayNode.addEventListener('mouseenter', () => {
          // Don't re-trigger if already loaded or loading
          if (nodeData.loadingState === 'loaded') return;
          
          // Unblock cascades when hovering a new node
          if (window.unblockCascades) {
            window.unblockCascades();
          }
          
          if (window.setHoveredNode) {
            window.setHoveredNode(nodeInfo.node.id);
          }
          
          // Only MEP Engineer can trigger loading animation on View 4
          // Other views work as before
          if (viewNum === 4 && !isMEPEngineer) return;
          
          // Start loading timer (1 second delay) only if idle
          if (nodeData.loadingState === 'idle') {
            nodeData.hoverTimer = setTimeout(() => {
              startNodeLoading(nodeData);
            }, 1000);
          }
        });
        
        overlayNode.addEventListener('mouseleave', () => {
          if (window.clearHoveredNode) {
            window.clearHoveredNode();
          }
          
          // If loaded, just reset so it can trigger again next time
          if (nodeData.loadingState === 'loaded') {
            nodeData.loadingState = 'idle';
            overlayNode.classList.remove('loaded');
            overlayNode.classList.remove('synced');
          } else {
            // Cancel loading if user leaves during loading
            cancelNodeLoading(nodeData);
          }
        });
        
        overlayContainer.appendChild(overlayNode);
        overlayNodeData.push(nodeData);
      });
      
      // Show container
      overlayContainer.classList.add('visible');
      overlayActive = true;
      
      // Start position update loop
      startOverlayPositionLoop();
      
      console.log(`Showing ${centerNodes.length} overlay nodes for view ${viewNum}`);
    }
    
