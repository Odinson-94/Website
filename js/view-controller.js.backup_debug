    // Global code flash interval for synchronized flashing
    let globalCodeFlashInterval = null;
    let pulseCodeFlashEnabled = false;
    
    // Flash code on ALL nodes simultaneously with role-specific codes
    function flashCodeOnAllNodes() {
      if (currentOverlayView !== 4) return;
      
      overlayNodeData.forEach(nodeData => {
        const codeEl = nodeData.element.querySelector('.node-code');
        if (!codeEl) return;
        
        // Get role-specific codes
        const codes = nodeSpecificCodes[nodeData.title] || nodeSpecificCodes['MEP Engineer'];
        const snippet = codes[Math.floor(Math.random() * codes.length)];
        codeEl.textContent = snippet;
        codeEl.classList.add('visible');
        
        setTimeout(() => {
          codeEl.classList.remove('visible');
        }, 200);
      });
    }
    
    // Flash code on a specific node by brain node ID (for hover - shows CODES)
    function flashCodeOnNodeById(brainNodeId) {
      if (currentOverlayView !== 4) return;
      
      // Find the overlay node that matches this brain node
      const nodeData = overlayNodeData.find(nd => nd.nodeId === brainNodeId);
      if (!nodeData) return;
      
      const codeEl = nodeData.element.querySelector('.node-code');
      if (!codeEl) return;
      
      // Get role-specific codes
      const codes = nodeSpecificCodes[nodeData.title] || nodeSpecificCodes['MEP Engineer'];
      const snippet = codes[Math.floor(Math.random() * codes.length)];
      codeEl.textContent = snippet;
      codeEl.style.color = ''; // Reset to default (teal from CSS)
      codeEl.classList.add('visible');
      
      setTimeout(() => {
        codeEl.classList.remove('visible');
      }, 150);
    }
    
    // Pulse callbacks are set up in the auto-signals section below
    
    // Enable/disable pulse-synced code flashing
    function enablePulseCodeFlash() {
      pulseCodeFlashEnabled = true;
    }
    
    function disablePulseCodeFlash() {
      pulseCodeFlashEnabled = false;
      // Clear all code displays
      overlayNodeData.forEach(nodeData => {
        const codeEl = nodeData.element.querySelector('.node-code');
        if (codeEl) codeEl.classList.remove('visible');
      });
    }
    
    // Legacy timer-based flashing (keeping for fallback)
    function startGlobalCodeFlashing(interval) {
      if (currentOverlayView !== 4) return;
      enablePulseCodeFlash();
    }
    
    // Stop synchronized code flashing
    function stopGlobalCodeFlashing() {
      disablePulseCodeFlash();
    }
    
    // Sync all nodes and show completion message (View 4 only for message)
    function syncAllNodes() {
      // All nodes glow together
      overlayNodeData.forEach(nodeData => {
        nodeData.element.classList.add('synced');
      });
      
      // Stop any code flashing
      stopGlobalCodeFlashing();
      
      // Stop auto signal questions permanently
      if (window.setProjectComplete) {
        window.setProjectComplete();
      }
      
      // Show big tick overlay on View 4
      if (currentOverlayView === 4) {
        const completeOverlay = document.getElementById('projectCompleteOverlay');
        if (completeOverlay) {
          completeOverlay.classList.add('visible');
          
          // Hide overlay after animation (longer to account for staged animation)
          setTimeout(() => {
            completeOverlay.classList.remove('visible');
          }, 5000);
        }
      }
      
      // Remove synced state after a moment
      setTimeout(() => {
        overlayNodeData.forEach(nodeData => {
          nodeData.element.classList.remove('synced');
        });
      }, 5000);
    }
    
    function startNodeLoading(nodeData) {
      const { element, nodeId } = nodeData;
      
      // Remove shine effect when loading starts
      element.classList.remove('mep-shine');
      
      // Start loading state - ring starts filling
      nodeData.loadingState = 'loading';
      element.classList.add('loading');
      
      // Set ring animation duration dynamically
      const ring = element.querySelector('.loading-ring circle');
      if (ring) {
        ring.style.animationDuration = (RING_DURATION / 1000) + 's';
      }
      
      // Start synchronized code flashing on ALL nodes
      startGlobalCodeFlashing(300);
      
      // Fire pulses throughout, ramping up quantity
      let elapsed = 0;
      const updateInterval = 120;
      
      nodeData.accelerateInterval = setInterval(() => {
        elapsed += updateInterval;
        const progress = Math.min(elapsed / RING_DURATION, 1);
        
        // Speed only increases slightly (1x to 1.4x)
        const pulseSpeed = 1.0 + progress * 0.4;
        
        if (window.setNodePulseSpeed) {
          window.setNodePulseSpeed(nodeId, pulseSpeed);
        }
        if (window.updatePulsesFromNode) {
          window.updatePulsesFromNode(nodeId, pulseSpeed);
        }
        
        // Fire pulses - quantity ramps up, peaks at 90%
        if (window.triggerNodePulse) {
          // Number of triggers: 1 at start, up to 3 near the end
          let triggers = 1;
          if (progress > 0.3) triggers = 2;
          if (progress > 0.6) triggers = 3;
          if (progress > 0.9) triggers = 2; // Slight ease off at very end
          
          for (let i = 0; i < triggers; i++) {
            window.triggerNodePulse(nodeId);
          }
        }
        
        // Complete loading when ring finishes
        if (progress >= 1) {
          completeNodeLoading(nodeData);
        }
      }, updateInterval);
    }
    
    function completeNodeLoading(nodeData) {
      const { element, nodeId } = nodeData;
      
      // Clear acceleration interval
      if (nodeData.accelerateInterval) {
        clearInterval(nodeData.accelerateInterval);
        nodeData.accelerateInterval = null;
      }
      
      // Stop synchronized code flashing
      stopGlobalCodeFlashing();
      
      // Block cascades from this node until another node is hovered
      if (window.blockCascadesFromNode) {
        window.blockCascadesFromNode(nodeId);
      }
      
      // STOP immediately - no more pulses
      if (window.clearHoveredNode) {
        window.clearHoveredNode();
      }
      
      // Reset pulse speed to normal
      if (window.setNodePulseSpeed) {
        window.setNodePulseSpeed(nodeId, 1.0);
      }
      
      // Set loaded state
      nodeData.loadingState = 'loaded';
      element.classList.remove('loading');
      element.classList.add('loaded');
      
      // ALL nodes glow together after loading completes
      syncAllNodes();
      
      // Reset after glow animation completes (matches overlay duration)
      setTimeout(() => {
        element.classList.remove('loaded');
        nodeData.loadingState = 'idle';
        // Restore mep-shine for MEP Engineer on View 4
        if (nodeData.isMEPEngineer && currentOverlayView === 4) {
          element.classList.add('mep-shine');
        }
      }, 5500);
    }
    
    function cancelNodeLoading(nodeData) {
      const { element, nodeId } = nodeData;
      
      // Clear timers
      if (nodeData.hoverTimer) {
        clearTimeout(nodeData.hoverTimer);
        nodeData.hoverTimer = null;
      }
      
      if (nodeData.accelerateInterval) {
        clearInterval(nodeData.accelerateInterval);
        nodeData.accelerateInterval = null;
      }
      
      // Stop synchronized code flashing
      stopGlobalCodeFlashing();
      
      // Reset visual state
      element.classList.remove('loading', 'loaded');
      nodeData.loadingState = 'idle';
      
      // Restore mep-shine for MEP Engineer on View 4
      if (nodeData.isMEPEngineer && currentOverlayView === 4) {
        element.classList.add('mep-shine');
      }
      
      // Reset pulse speed
      if (window.setNodePulseSpeed) {
        window.setNodePulseSpeed(nodeId, 1.0);
      }
    }
    
    function hideOverlayNodes() {
      overlayActive = false;
      overlayContainer.classList.remove('visible');
      
      // Cancel any loading states
      overlayNodeData.forEach(nodeData => {
        cancelNodeLoading(nodeData);
      });
      
      // Clear hovered node if any
      if (window.clearHoveredNode) {
        window.clearHoveredNode();
      }
      
      // Stop animation loop
      if (overlayAnimationFrame) {
        cancelAnimationFrame(overlayAnimationFrame);
        overlayAnimationFrame = null;
      }
      
      // Clear after fade out
      setTimeout(() => {
        if (!overlayContainer.classList.contains('visible')) {
          overlayContainer.innerHTML = '';
          overlayNodeData = [];
        }
      }, 500);
    }
    
    // Update overlay node positions to match brain node screen positions
    function updateOverlayPositions() {
      if (!overlayActive || !window.getNodeCurrentScreenPos) return;
      
      overlayNodeData.forEach(({ element, nodeId }) => {
        const pos = window.getNodeCurrentScreenPos(nodeId);
        if (pos) {
          element.style.left = pos.x + 'px';
          element.style.top = pos.y + 'px';
        }
      });
    }
    
    // Animation loop for overlay positions
    function startOverlayPositionLoop() {
      if (overlayAnimationFrame) return; // Already running
      
      function loop() {
        if (!overlayActive) {
          overlayAnimationFrame = null;
          return;
        }
        updateOverlayPositions();
        overlayAnimationFrame = requestAnimationFrame(loop);
      }
      overlayAnimationFrame = requestAnimationFrame(loop);
    }
    
    // Menubar hover effect is now in js/menubar.js - SINGLE SOURCE OF TRUTH
    
    // Dark mode toggle
    // Note: Toggle visual state is purely CSS-based (html.dark-mode .toggle-switch)
    // No .active class needed - CSS responds to html.dark-mode immediately
    // Cookie helper functions
    function setDarkModeCookie(enabled) {
      // Cookie expires in 1 year, accessible site-wide
      document.cookie = `darkMode=${enabled}; path=/; max-age=31536000; SameSite=Lax`;
      // Also set localStorage as backup
      localStorage.setItem('darkMode', enabled);
    }
    
    function getDarkModeCookie() {
      const match = document.cookie.match(/(?:^|; )darkMode=([^;]*)/);
      return match ? match[1] === 'true' : false;
    }
    
    toggleSwitch.addEventListener('click', () => {
      document.documentElement.classList.toggle('dark-mode');
      const isDark = document.documentElement.classList.contains('dark-mode');
      setDarkModeCookie(isDark);
      if (window.setDarkMode) {
        window.setDarkMode(isDark);
      }
    });
    
    // Set initial brain.js dark mode state from cookie (after brain.js loads)
    // Use a small delay to ensure brain.js has initialized
    setTimeout(() => {
      const darkModeEnabled = getDarkModeCookie() || localStorage.getItem('darkMode') === 'true';
      if (window.setDarkMode && darkModeEnabled) {
        window.setDarkMode(true);
      }
    }, 100);
    
    // --------------------------------------------------
    // COLOR PALETTE SYNC
    // --------------------------------------------------
    // Both dropdowns (dark toggle area + chat settings) share the same color selection
    
    function initColorPaletteSync() {
      // Apply background colors to swatches from data-color attribute
      document.querySelectorAll('.color-swatch[data-color]').forEach(swatch => {
        swatch.style.backgroundColor = swatch.dataset.color;
      });
      
      // Handle color swatch clicks
      const allColorSwatches = document.querySelectorAll('.color-swatch');
      
      allColorSwatches.forEach(swatch => {
        swatch.addEventListener('click', (e) => {
          e.stopPropagation();
          const selectedColor = swatch.dataset.color;
          
          // Update all swatches across both dropdowns
          document.querySelectorAll('.color-swatch').forEach(s => {
            if (s.dataset.color === selectedColor) {
              s.classList.add('active');
            } else {
              s.classList.remove('active');
            }
          });
          
          // Store selection in localStorage for persistence
          localStorage.setItem('colorPalette', selectedColor);
          
          // Dispatch event for future color application
          window.dispatchEvent(new CustomEvent('paletteChanged', { 
            detail: { color: selectedColor } 
          }));
          
          console.log('Color selected:', selectedColor);
        });
      });
      
      // Handle "More Colors" button clicks
      const moreColorsBtn = document.getElementById('moreColorsBtn');
      const customColorPicker = document.getElementById('customColorPicker');
      const chatMoreColorsBtn = document.querySelector('.chat-more-colors');
      const chatCustomColorPicker = document.querySelector('.chat-custom-color');
      
      if (moreColorsBtn && customColorPicker) {
        moreColorsBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          customColorPicker.click();
        });
        
        customColorPicker.addEventListener('input', (e) => {
          const selectedColor = e.target.value;
          applyCustomColor(selectedColor);
        });
      }
      
      if (chatMoreColorsBtn && chatCustomColorPicker) {
        chatMoreColorsBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          chatCustomColorPicker.click();
        });
        
        chatCustomColorPicker.addEventListener('input', (e) => {
          const selectedColor = e.target.value;
          applyCustomColor(selectedColor);
        });
      }
      
      function applyCustomColor(color) {
        // Remove active from all swatches
        document.querySelectorAll('.color-swatch').forEach(s => {
          s.classList.remove('active');
        });
        
        // Store and dispatch
        localStorage.setItem('colorPalette', color);
        window.dispatchEvent(new CustomEvent('paletteChanged', { 
          detail: { color: color } 
        }));
        
        console.log('Custom color selected:', color);
      }
      
      // Restore saved color on load
      const savedColor = localStorage.getItem('colorPalette');
      if (savedColor) {
        document.querySelectorAll('.color-swatch').forEach(s => {
          if (s.dataset.color && s.dataset.color.toLowerCase() === savedColor.toLowerCase()) {
            s.classList.add('active');
          } else {
            s.classList.remove('active');
          }
        });
      }
    }
    
    initColorPaletteSync();
    
    // --------------------------------------------------
    // MENU NAVIGATION CLICK HANDLERS
    // --------------------------------------------------
    // These run on DOMContentLoaded so they work from any page
    
    const menuHome = document.getElementById('menuHome');
    
    if (menuHome) {
      menuHome.addEventListener('click', (e) => {
        e.preventDefault();
        navigateToView(1);
      });
    }
    
    function sleep(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }
    
    // --------------------------------------------------
    // MAIN ANIMATION SEQUENCE
    // --------------------------------------------------
    // Runs on page load: fade in brain, show logo, move brain left.
    // This is View 0 -> View 1 transition.
    // If #about hash is present, skip directly to About Us (view 9).
    
    async function runMainAnimation() {
      if (window.PERF) window.PERF.mark('runMainAnimation START');
      
      // Check for hash-based navigation BEFORE anything else
      const hash = window.location.hash.toLowerCase();
      const skipToAbout = (hash === '#about');
      
      // ===== SPECIAL CASE: #about anchor on initial page load =====
      // Skip ALL intro animation and go directly to About Us
      if (skipToAbout) {
        // Clear the hash so refreshing doesn't keep going to about
        history.replaceState(null, '', window.location.pathname);
        
        // Set view to About Us (9) instantly - brain appears visible immediately
        currentView = 9;
        if (window.setViewInstant) {
          window.setViewInstant(9, true); // true = make brain visible instantly
        }
        updateSectionIndicator(9);
        
        // Show UI elements immediately
        logo.classList.add('visible');
        menubar.classList.add('visible');
        sectionIndicator.classList.add('visible');
        darkToggle.classList.add('visible');
        rightPanel.classList.add('visible');
        
        // Show About Us panel immediately
        const aboutUsPanel = document.getElementById('aboutUsPanel');
        if (aboutUsPanel) aboutUsPanel.classList.add('visible');
        
        // Enable scroll detection
        enableScrollDetection();
        
        // Start neural network animations
        if (window.startNeuralAnimations) {
          window.startNeuralAnimations();
        }
        
        console.log('Deep link to #about - skipped intro animation');
        return;
      }
      
      // ===== NORMAL PAGE LOAD: Full intro animation =====
      
      // Mark as transitioning (animation phase = interruptible)
      isTransitioning = true;
      animationPhase = true;
      
      // Start at View 0 (brain centered, full size)
      currentView = 0;
      setTargetView(0);
      updateSectionIndicator(0);
      if (window.PERF) window.PERF.mark('View 0 set');
      
      // Enable scroll detection early so user can interrupt
      enableScrollDetection();
      
      // Brain fades in quickly (handled by brain.js)
      await sleep(500);
      if (window.PERF) window.PERF.mark('After 500ms sleep');
      
      // Start neural network pulse animations immediately as brain appears
      if (window.startNeuralAnimations) {
        window.startNeuralAnimations();
      }
      
      // Check for interruption - if target changed, abort intro
      if (!isTargetView(0)) {
        console.log('Intro interrupted at phase 1, aborting');
        return;
      }
      
      // Wait for brain to be visible
      await sleep(1500);
      if (window.PERF) window.PERF.mark('After 1500ms sleep - brain should be visible');
      
      // Check for interruption
      if (!isTargetView(0)) {
        console.log('Intro interrupted at phase 2, aborting');
        return;
      }
      
      // Show logo, menubar, section indicator
      logo.classList.add('visible');
      menubar.classList.add('visible');
      sectionIndicator.classList.add('visible');
      darkToggle.classList.add('visible');
      if (window.PERF) window.PERF.mark('UI elements shown (logo, menubar, etc)');
      
      await sleep(1000);
      if (window.PERF) window.PERF.mark('After 1000ms sleep');
      
      // STAY AT VIEW 0 - don't auto-transition to View 1
      // User scrolls/clicks to continue
      
      // Start auto-hover on view 0
      updateAutoHover(0);
      
      // Show scroll indicator so user can click to continue
      await sleep(500);
      scrollIndicator.classList.add('visible');
      
      // Mark intro complete - stay at View 0
      isTransitioning = false;
      animationPhase = false;
      
      if (window.PERF) {
        window.PERF.mark('VIEW 0 FULLY LOADED - Waiting for user scroll');
        window.PERF.summary();
      }
    }
    
    // --------------------------------------------------
    // STATE TRACKING
    // --------------------------------------------------
    
    let scrollTriggered = false;
    let scrollEnabled = false;
    
    // Back to top button
    const backToTop = document.getElementById('backToTop');
    
    function updateBackToTop() {
      // Hide for views 0 and 1, show for views 2+
      if (currentView > 1) {
        backToTop.classList.add('visible');
      } else {
        backToTop.classList.remove('visible');
      }
    }
    
    // --------------------------------------------------
    // HIDE ALL PANELS
    // --------------------------------------------------
    // Called immediately when navigation starts to prevent text bleeding.
    
    function hideAllPanels() {
      // Hide hero text (View 1)
      const heroTextContainer = document.getElementById('heroTextContainer');
      if (heroTextContainer) {
        heroTextContainer.classList.remove('visible');
        heroTextContainer.classList.add('fade-out');
      }
      
      // Hide thinking section (View 2)
      const thinkingSection = document.getElementById('thinkingSection');
      if (thinkingSection) thinkingSection.classList.remove('visible');
      
      // Hide all demo view overlays (Views 3-11)
      const demoIntroOverlay = document.getElementById('demoIntroOverlay');
      const gifOverlay = document.getElementById('gifOverlay');
      const schematicsOverlay = document.getElementById('schematicsOverlay');
      const modellingOverlay = document.getElementById('modellingOverlay');
      const schedulesOverlay = document.getElementById('schedulesOverlay');
      const specWritingOverlay = document.getElementById('specWritingOverlay');
      const archBuildOverlay = document.getElementById('archBuildOverlay');
      const comingSoonOverlay = document.getElementById('comingSoonOverlay');
      const buildXOverlay = document.getElementById('buildXOverlay');
      
      if (demoIntroOverlay) demoIntroOverlay.classList.remove('visible');
      if (gifOverlay) gifOverlay.classList.remove('visible');
      if (schematicsOverlay) schematicsOverlay.classList.remove('visible');
      if (modellingOverlay) modellingOverlay.classList.remove('visible');
      if (schedulesOverlay) schedulesOverlay.classList.remove('visible');
      if (specWritingOverlay) specWritingOverlay.classList.remove('visible');
      if (archBuildOverlay) archBuildOverlay.classList.remove('visible');
      if (comingSoonOverlay) comingSoonOverlay.classList.remove('visible');
      if (buildXOverlay) buildXOverlay.classList.remove('visible');
      
      // Remove dark mode added for View 11 (only if not user-enabled via toggle)
      // Check if dark mode cookie/localStorage is NOT set - then remove
      const darkModeCookie = document.cookie.match(/(?:^|; )darkMode=([^;]*)/);
      const darkModeEnabled = (darkModeCookie && darkModeCookie[1] === 'true') || localStorage.getItem('darkMode') === 'true';
      if (!darkModeEnabled) {
        document.documentElement.classList.remove('dark-mode');
      }
      document.body.classList.remove('view-dark-header');
      
      // Stop auto signal firing for questions
      if (window.stopAutoSignals) window.stopAutoSignals();
      
      // Hide RIBA left panel and cleanup
      const ribaLeftPanel = document.getElementById('ribaLeftPanel');
      const ribaBackdrop = document.getElementById('ribaBackdrop');
      if (ribaLeftPanel) {
        ribaLeftPanel.classList.remove('visible');
        ribaLeftPanel.classList.remove('scroll-locked');
        ribaLeftPanel.style.paddingRight = ''; // Reset scrollbar compensation
        document.querySelectorAll('.riba-card-left').forEach(c => {
          c.style.visibility = '';
        });
        document.querySelectorAll('.riba-clone-expanded').forEach(c => c.remove());
      }
      if (ribaBackdrop) ribaBackdrop.classList.remove('visible');
      // Show section indicator again when leaving About Us
      if (sectionIndicator) sectionIndicator.classList.remove('hidden');
      const demoChatContainerHide = document.getElementById('demoChatContainer');
      if (demoChatContainerHide) demoChatContainerHide.classList.remove('visible');
      
      // Cancel any running loading states on overlay nodes
      overlayNodeData.forEach(nodeData => {
        cancelNodeLoading(nodeData);
      });
      
      // Hide overlay nodes
      overlayActive = false;
      if (window.clearHoveredNode) {
        window.clearHoveredNode();
      }
      if (overlayAnimationFrame) {
        cancelAnimationFrame(overlayAnimationFrame);
        overlayAnimationFrame = null;
      }
      overlayContainer.classList.remove('visible');
      overlayContainer.innerHTML = '';
      overlayNodeData = [];
    }
    
    // --------------------------------------------------
    // SCROLL DETECTION
    // --------------------------------------------------
    // Handles wheel and touch scrolling.
    // Animation phase: CAN be interrupted (smooth handoff to new target)
    // Content phase: CANNOT be interrupted (prevents text bleeding)
    // Scroll only moves +1/-1 from target view, anchors can jump anywhere
    
    function enableScrollDetection() {
      if (scrollEnabled) return;
      scrollEnabled = true;
      console.log('Scroll detection enabled');
      
      // Wheel scroll handler
      document.addEventListener('wheel', handleWheelSnap, { passive: false });
      
      // Touch support
      let touchStartY = 0;
      let touchStartTarget = null;
      document.addEventListener('touchstart', (e) => {
        touchStartY = e.touches[0].clientY;
        touchStartTarget = e.target;
      }, { passive: true });
      
      document.addEventListener('touchend', (e) => {
        // Check if touch originated from inside a scrollable panel
        const scrollablePanels = [
          '.demo-chat-messages',
          '.demo-history-list',
          '.demo-outputs-tree',
          '.demo-chat-history-sidebar',
          '.demo-revit-box',
          '.demo-chat-box',
          '.demo-chat-wrapper',
          '.demo-containers-stack',
          '.sidebar-panel',
          '.riba-left-panel',
          '.about-us-panel'
        ];
        
        for (const selector of scrollablePanels) {
          if (touchStartTarget && touchStartTarget.closest(selector)) {
            // Let the panel handle its own scroll - don't change views
            return;
          }
        }
        
        const touchEndY = e.changedTouches[0].clientY;
        const diff = touchStartY - touchEndY;
        
        if (Math.abs(diff) > 50) {
          handleScrollDirection(diff > 0 ? 'down' : 'up');
        }
      }, { passive: true });
      
      // Back to top click handler
      backToTop.addEventListener('click', () => navigateToView(0));
    }
    
    function handleWheelSnap(e) {
      if (!scrollEnabled) return;
      
      // Block scrolling when RIBA panel card is expanded
      const ribaPanel = document.getElementById('ribaLeftPanel');
      if (ribaPanel && ribaPanel.classList.contains('scroll-locked')) {
        return;
      }
      
      // Check if scroll originated from inside a scrollable panel
      // If so, let the panel scroll naturally - don't change views
      const scrollablePanels = [
        '.demo-chat-messages',
        '.demo-history-list',
        '.demo-outputs-tree',
        '.demo-chat-history-sidebar',
        '.demo-revit-box',
        '.demo-chat-box',
        '.demo-chat-wrapper',
        '.demo-containers-stack',
        '.sidebar-panel',
        '.riba-left-panel',
        '.about-us-panel'
      ];
      
      for (const selector of scrollablePanels) {
        if (e.target.closest(selector)) {
          // Let the panel handle its own scroll - don't change views
          return;
        }
      }
      
      e.preventDefault();
      
      handleScrollDirection(e.deltaY > 0 ? 'down' : 'up');
    }
    
    // Scroll throttling - ignore rapid wheel events from sensitive mice
    let lastScrollTime = 0;
    const SCROLL_COOLDOWN = 150; // ms - ignore scrolls within this window
    
    function handleScrollDirection(direction) {
      // Block scrolling when RIBA panel card is expanded
      const ribaPanel = document.getElementById('ribaLeftPanel');
      if (ribaPanel && ribaPanel.classList.contains('scroll-locked')) {
        return;
      }
      
      // Throttle rapid scrolls (gaming mice, trackpads)
      const now = performance.now();
      if (now - lastScrollTime < SCROLL_COOLDOWN) {
        return; // Ignore - too soon after last scroll
      }
      lastScrollTime = now;
      
      // During content loading phase - block completely
      if (isTransitioning && !animationPhase) {
        console.log('Scroll blocked - content loading phase');
        return;
      }
      
      // Calculate next view based on TARGET view (handles interruption correctly)
      // If interrupting, we go +1/-1 from where we're GOING, not where we ARE
      const baseView = isTransitioning ? targetViewIndex : currentView;
      let nextView = baseView;
      
      if (direction === 'down') {
        // Scroll down - go to next view
        if (baseView < 11) {  // 12 views total (0-11)
          nextView = baseView + 1;
        }
      } else {
        // Scroll up - go to previous view
        if (baseView > 0) {
          nextView = baseView - 1;
        }
      }
      
      // Only navigate if we have a new target
      if (nextView !== baseView) {
        navigateToView(nextView);
      }
    }
    
    // --------------------------------------------------
    // VIEW 2 CONTENT FUNCTIONS
    // --------------------------------------------------
    
    function showView2ContentInstantly() {
      const servicesSection = document.getElementById('servicesSection');
      const softwareCarousel = document.getElementById('softwareCarousel');
      
      // Show services section and all lines
      if (servicesSection) {
        servicesSection.classList.add('visible');
        const allLines = servicesSection.querySelectorAll('.line');
        allLines.forEach(l => l.classList.add('visible'));
      }
      
      // Show carousel
      if (softwareCarousel) softwareCarousel.classList.add('visible');
      
      scrollIndicator.classList.add('visible');
    }
    
    // --------------------------------------------------
    // RESET VIEW 2 CONTENT
    // --------------------------------------------------
    
    function resetView2Content() {
      const servicesSection = document.getElementById('servicesSection');
      
      if (servicesSection) {
        servicesSection.classList.remove('visible');
        const lines = servicesSection.querySelectorAll('.line');
        lines.forEach(l => l.classList.remove('visible'));
      }
      
      // Reset carousel
      const carousel = document.getElementById('softwareCarousel');
      if (carousel) carousel.classList.remove('visible');
    }
    
    // --------------------------------------------------
    // SCROLL INDICATOR CLICK
    // --------------------------------------------------
    
    scrollIndicator.addEventListener('click', () => {
      if (!scrollEnabled) return;
      if (currentView < 7) {
        navigateToView(currentView + 1);
      }
    });
    
    // --------------------------------------------------
    // VIEW 3 CHAT FUNCTIONS
    // --------------------------------------------------
    
    function openChat() {
      const demoChatContainer = document.getElementById('demoChatContainer');
      if (demoChatContainer) {
        demoChatContainer.classList.add('visible');
      }
      
      // Scroll chat to bottom (like demos.html)
      const chatMessages = document.getElementById('chatMessages');
      if (chatMessages) {
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      
      // Stop shine animation on all Open Chat buttons
      document.querySelectorAll('.open-chat-btn').forEach(btn => {
        btn.classList.add('clicked');
      });
    }
    
    function resetGifState() {
      // Reset floating chat messages to initial state with inline options
      const chatMessages = document.getElementById('chatMessages');
      if (chatMessages) {
        chatMessages.innerHTML = `
          <div class="demo-msg-bot">
            <p>Welcome — select a plan option below or type your request.</p>
            <div class="demo-inline-options">
              <button class="demo-option-btn" data-plan="1">Option 1</button>
              <button class="demo-option-btn" data-plan="2">Option 2</button>
              <button class="demo-option-btn" data-plan="3">Option 3</button>
              <button class="demo-option-btn" data-plan="4">Option 4</button>
            </div>
          </div>
        `;
        // Re-attach click handlers and scroll to bottom
        if (typeof attachInlineOptionHandlers === 'function') {
          attachInlineOptionHandlers();
        }
        chatMessages.scrollTop = chatMessages.scrollHeight;
      }
      
      // Reset session to Plan Options
      document.querySelectorAll('#floatingChatHistory .demo-history-item').forEach(item => {
        if (item.dataset.session === 'plan-options') {
          item.classList.add('active');
        } else {
          item.classList.remove('active');
        }
      });
      
      // Reset new View 3 GIF state
      const gifSectionIndex4 = document.getElementById('gifSectionIndex4');
      if (gifSectionIndex4) {
        const img = gifSectionIndex4.querySelector('img');
        if (img) img.classList.remove('playing');
        const placeholder = gifSectionIndex4.querySelector('.demo-revit-placeholder');
        if (placeholder) placeholder.style.display = 'block';
      }
    }
    
    // Reset chat container position (called when leaving View 3)
    function resetChatContainer() {
      const demoChatContainer = document.getElementById('demoChatContainer');
      if (demoChatContainer) {
        demoChatContainer.classList.remove('visible');
        demoChatContainer.style.left = '';
        demoChatContainer.style.top = '';
        demoChatContainer.style.bottom = '';
        demoChatContainer.style.right = '';
        demoChatContainer.style.transform = '';
        demoChatContainer.style.width = '';
        demoChatContainer.style.height = '';
      }
      resetGifState();
    }
      
    // --------------------------------------------------
    // DEMO FUNCTIONALITY
    // --------------------------------------------------
    
    let isGifTransitioning = false;
    const validCommands = ['plan routes', 'size emitters', 'note drawings', 'write spec', 'produce 3d model', 'clash coordinate revit', 'produce 3d', 'clash coordinate'];
    
    function attachDemoButtonHandlers() {
      document.querySelectorAll('.inline-demo-btn').forEach(btn => {
        // Skip output buttons - they have their own onclick handlers
        if (btn.classList.contains('see-output-btn')) return;
        
        btn.addEventListener('click', async function() {
          if (isGifTransitioning) return;
          
          const title = this.getAttribute('data-title');
          if (!title) return; // Safety check
          
          // Skip if "See more Demos"
          if (this.getAttribute('data-demo') === 'see-more') {
            await addThinkingAnimation();
            addBotMessage("More demos coming soon! Please select from the available options above.");
            return;
          }
          
          // Remove active from all, add to clicked
          document.querySelectorAll('.inline-demo-btn').forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          
          // Add user message equivalent
          addUserMessage(title);
          
          // Show thinking animation and wait for it to complete
          await addThinkingAnimation();
          
          // Show response and play demo
          addBotMessage(`Loading ${title} demo...`);
          await playDemo(title);
        });
      });
    }
    
    // Initial attachment
    attachDemoButtonHandlers();
    
    async function playDemo(title) {
      if (isGifTransitioning) return;
      
      isGifTransitioning = true;
      
      // Play the new View 3 GIF if available
      const gifSectionIndex4 = document.getElementById('gifSectionIndex4');
      if (gifSectionIndex4) {
        const img = gifSectionIndex4.querySelector('img');
        const placeholder = gifSectionIndex4.querySelector('.demo-revit-placeholder');
        
        if (img && placeholder) {
          // Hide placeholder
          placeholder.style.display = 'none';
          
          // Force reload GIF to restart it
          const gifSrc = img.src;
          img.src = '';
          img.src = gifSrc;
          
          // Show GIF with fade in
          await sleep(50);
          img.classList.add('playing');
        }
      }
      
      isGifTransitioning = false;
    }
    
    async function addThinkingAnimation() {
      const chatMessages = document.getElementById('chatMessages');
      const persistentNode = document.getElementById('chatPersistentNode');
      
      // Create thinking content (no node - we use the persistent one)
      const thinkingDiv = document.createElement('div');
      thinkingDiv.className = 'chat-thinking';
      thinkingDiv.id = 'chatThinking';
      thinkingDiv.innerHTML = `
        <div class="chat-thinking-content" id="chatThinkingContent">
          <div class="chat-thinking-header" id="chatThinkingHeader">
            <span>Thinking...</span>
          </div>
          <ul class="chat-steps-list" id="chatStepsList">
            <li><span class="chat-step-icon">●</span> Analyzing request</li>
            <li><span class="chat-step-icon">●</span> Loading context</li>
            <li><span class="chat-step-icon">●</span> Preparing response</li>
          </ul>
        </div>
      `;
      chatMessages.appendChild(thinkingDiv);
      
      // Scroll to bottom
      const chatBody = document.getElementById('demoChatBody');
      chatBody.scrollTop = chatBody.scrollHeight;
      
      // Get elements
      const content = document.getElementById('chatThinkingContent');
      const header = document.getElementById('chatThinkingHeader');
      const stepsList = document.getElementById('chatStepsList');
      const steps = stepsList.querySelectorAll('li');
      
      // Step 1: Activate persistent node (start processing)
      persistentNode.classList.add('processing');
      await sleep(100);
      
      // Step 2: Move node to left
      persistentNode.classList.add('left');
      await sleep(400);
      
      // Step 3: Show thinking content above node
      content.classList.add('visible');
      await sleep(200);
      
      // Step 4: Expand steps list
      stepsList.classList.add('expanded');
      
      // Step 5: Reveal steps one by one
      for (let i = 0; i < steps.length; i++) {
        steps[i].classList.add('visible');
        await sleep(250);
      }
      
      // Mark as done
      header.classList.add('done');
      header.querySelector('span').textContent = '3 steps';
      
      await sleep(400);
      
      // Step 6: Collapse steps
      stepsList.classList.remove('expanded');
      await sleep(300);
      
      // Step 7: Collapse content
      content.classList.add('collapsing');
      content.classList.remove('visible');
      await sleep(300);
      
      // Step 8: Move node back to right
      persistentNode.classList.remove('left');
      await sleep(400);
      
      // Step 9: Keep pulsing for half a second longer
      await sleep(500);
      
      // Step 10: Stop processing - dim but keep visible
      persistentNode.classList.remove('processing');
    }
    
    function removeThinkingAnimation() {
      const thinkingDiv = document.getElementById('chatThinking');
      if (thinkingDiv) {
        thinkingDiv.remove();
      }
    }
    
    function addBotMessage(text) {
      removeThinkingAnimation();
      const chatMessages = document.getElementById('chatMessages');
      const messageDiv = document.createElement('div');
      messageDiv.className = 'demo-msg-bot';
      messageDiv.innerHTML = `<p>${text}</p>`;
      chatMessages.appendChild(messageDiv);
      
      // Scroll to bottom
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    
    function addUserMessage(text) {
      const chatMessages = document.getElementById('chatMessages');
      const messageDiv = document.createElement('div');
      messageDiv.className = 'demo-msg-user';
      messageDiv.innerHTML = `<p>${text}</p>`;
      chatMessages.appendChild(messageDiv);
      
      // Scroll to bottom
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    
    // Plan images for Revit panel - used by floating chat
    const floatingChatPlanImages = ['images/backgrounds/PLAN_A.png', 'images/backgrounds/PLAN_B.png', 'images/backgrounds/PLAN_C.png', 'images/backgrounds/PLAN_D.png'];
    let currentChatSession = 'plan-options'; // 'base-layout' or 'plan-options'
    
    // Handle session selection (Base Layout vs Plan Options)
    function selectChatSession(sessionType) {
      currentChatSession = sessionType;
      const chatMessages = document.getElementById('chatMessages');
      
      // Update session history active state
      document.querySelectorAll('#floatingChatHistory .demo-history-item').forEach(item => {
        if (item.dataset.session === sessionType) {
          item.classList.add('active');
        } else {
          item.classList.remove('active');
        }
      });
      
      if (sessionType === 'base-layout') {
        // Show base layout conversation
        chatMessages.innerHTML = `
          <div class="demo-msg-bot">
            <p>I've received the measured building survey data. Analysing spatial constraints and existing structure...</p>
          </div>
          <div class="demo-msg-bot">
            <p>Survey processed. I've identified 2,450m² of usable floor area across 3 levels. Structural grid is 7.5m x 9m. Ceiling void available: 450mm.</p>
          </div>
          <div class="demo-msg-user">
            <p>What about the services risers?</p>
          </div>
          <div class="demo-msg-bot">
            <p>I've located 4 existing risers from the survey. Primary riser at grid intersection C-3 with 2.4m² available. Secondary risers at A-1, E-1, and E-5 with 1.2m² each.</p>
          </div>
          <div class="demo-msg-bot">
            <p>Base layout is ready. Switch to Plan Options to explore layout variations.</p>
          </div>
        `;
      } else {
        // Show plan options conversation with inline buttons
        chatMessages.innerHTML = `
          <div class="demo-msg-bot">
            <p>Welcome — select a plan option below or type your request.</p>
            <div class="demo-inline-options">
              <button class="demo-option-btn" data-plan="1">Option 1</button>
              <button class="demo-option-btn" data-plan="2">Option 2</button>
              <button class="demo-option-btn" data-plan="3">Option 3</button>
              <button class="demo-option-btn" data-plan="4">Option 4</button>
            </div>
          </div>
        `;
        // Re-attach click handlers for inline buttons
        attachInlineOptionHandlers();
      }
      
      // Scroll to bottom after content change
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
    
    // Attach click handlers to inline option buttons
    function attachInlineOptionHandlers() {
      document.querySelectorAll('.demo-option-btn').forEach(btn => {
        btn.addEventListener('click', function() {
          const planNum = parseInt(this.dataset.plan);
          if (planNum >= 1 && planNum <= 4) {
            selectPlanOption(planNum - 1);
          }
        });
      });
    }
    
    // Initial attachment
    attachInlineOptionHandlers();
    
    // Handle plan option selection (from inline buttons or typed command)
    async function selectPlanOption(planIndex) {
      const revitPlanImageEl = document.getElementById('revitPlanImage');
      
      // Make sure we're in plan-options session
      if (currentChatSession !== 'plan-options') {
        selectChatSession('plan-options');
        await sleep(100);
      }
      
      // Update inline button active state
      document.querySelectorAll('.demo-option-btn').forEach((btn, idx) => {
        if (idx === planIndex) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
      });
      
      // Add bot message
      addBotMessage(`Switching to Option ${planIndex + 1}...`);
      
      // If Revit panel is visible, update the plan
      if (revitPlanImageEl) {
        revitPlanImageEl.classList.add('fade-out');
        await sleep(300);
        revitPlanImageEl.src = floatingChatPlanImages[planIndex];
        await sleep(50);
        revitPlanImageEl.classList.remove('fade-out');
      }
      
      await sleep(500);
      
      const planDescriptions = [
        'Open plan layout loaded. This design maximises floor area with minimal partitions.',
        'Cellular offices configured. Private workspaces arranged along the perimeter.',
        'Hybrid layout applied. Mix of open areas and enclosed meeting rooms.',
        'Collaborative zones established. Breakout spaces and team areas positioned.'
      ];
      
      addBotMessage(planDescriptions[planIndex]);
    }
    
    // Session history click handlers
    document.querySelectorAll('#floatingChatHistory .demo-history-item').forEach(item => {
      item.addEventListener('click', function() {
        const session = this.dataset.session;
        if (session) {
          selectChatSession(session);
        }
      });
    });
    
    // Send button functionality
    const demoChatInput = document.getElementById('demoChatInput');
    const demoChatSendBtn = document.getElementById('demoChatSendBtn');
    
    async function handleSend() {
      const input = demoChatInput.value.trim();
      if (!input) return;
      
      // Add user message
      addUserMessage(input);
      demoChatInput.value = '';
      
      // Check for option commands
      const inputLower = input.toLowerCase();
      
      if (inputLower.includes('option 1') || inputLower === '1') {
        await selectPlanOption(0);
      } else if (inputLower.includes('option 2') || inputLower === '2') {
        await selectPlanOption(1);
      } else if (inputLower.includes('option 3') || inputLower === '3') {
        await selectPlanOption(2);
      } else if (inputLower.includes('option 4') || inputLower === '4') {
        await selectPlanOption(3);
      } else if (inputLower.includes('change') || inputLower.includes('next') || inputLower.includes('cycle')) {
        // Cycle through plans
        const activeItem = document.querySelector('#floatingChatOptions .demo-history-item.active');
        const currentIndex = activeItem ? parseInt(activeItem.dataset.plan) - 1 : 0;
        const nextIndex = (currentIndex + 1) % 4;
        await selectPlanOption(nextIndex);
      } else {
        // Unrecognized command
        await sleep(300);
        addBotMessage("Please select an option from the sidebar or type 'option 1' through 'option 4' to switch layouts.");
      }
    }
    
    if (demoChatSendBtn) {
      demoChatSendBtn.addEventListener('click', handleSend);
    }
    if (demoChatInput) {
      demoChatInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          handleSend();
        }
      });
    }
    
    // Close button (was minimize) - only if floating chat exists
    const demoMinimizeBtn = document.getElementById('demoMinimizeBtn');
    if (demoMinimizeBtn) {
      demoMinimizeBtn.addEventListener('click', function() {
        const container = document.getElementById('demoChatContainer');
        if (container) container.classList.remove('visible');
      });
    }
    
    // Draggable demo container - only if it exists
    const demoChatContainer = document.getElementById('demoChatContainer');
    const demoChatHeader = document.getElementById('demoChatHeader');
    let isDraggingDemo = false;
    let demoStartX, demoStartY, demoInitialX, demoInitialY;
    
    if (demoChatHeader && demoChatContainer) demoChatHeader.addEventListener('mousedown', function(e) {
      if (e.target.tagName === 'BUTTON') return;
      isDraggingDemo = true;
      demoStartX = e.clientX;
      demoStartY = e.clientY;
      
      // Get actual pixel position from bounding rect
      const rect = demoChatContainer.getBoundingClientRect();
      demoInitialX = rect.left;
      demoInitialY = rect.top;
      
      // Convert from right-positioned to left-positioned before dragging
      // This prevents jump caused by CSS right property conflicting with left
      demoChatContainer.style.right = 'auto';
      demoChatContainer.style.left = demoInitialX + 'px';
      demoChatContainer.style.top = demoInitialY + 'px';
      demoChatContainer.style.transform = 'none';
      demoChatContainer.classList.add('dragging');
    });
    
    document.addEventListener('mousemove', function(e) {
      if (!isDraggingDemo || !demoChatContainer) return;
      const deltaX = e.clientX - demoStartX;
      const deltaY = e.clientY - demoStartY;
      demoChatContainer.style.left = (demoInitialX + deltaX) + 'px';
      demoChatContainer.style.top = (demoInitialY + deltaY) + 'px';
    });
    
    document.addEventListener('mouseup', function() {
      if (isDraggingDemo && demoChatContainer) {
        isDraggingDemo = false;
        demoChatContainer.classList.remove('dragging');
      }
    });
    
    // Resizable demo container from any edge (scoped to demoChatContainer only)
    let isResizing = false;
    let resizeDirection = null;
    let resizeStartX, resizeStartY, resizeStartWidth, resizeStartHeight, resizeStartLeft, resizeStartTop;
    
    // Only attach to resize edges within demoChatContainer, not global
    if (demoChatContainer) {
      demoChatContainer.querySelectorAll('.resize-edge').forEach(edge => {
        edge.addEventListener('mousedown', function(e) {
          if (!demoChatContainer) return;
          e.preventDefault();
          e.stopPropagation();
          isResizing = true;
          resizeDirection = this.getAttribute('data-resize');
          resizeStartX = e.clientX;
          resizeStartY = e.clientY;
          const rect = demoChatContainer.getBoundingClientRect();
          resizeStartWidth = rect.width;
          resizeStartHeight = rect.height;
          resizeStartLeft = rect.left;
          resizeStartTop = rect.top;
        });
      });
    }
    
    document.addEventListener('mousemove', function(e) {
      if (!isResizing || !demoChatContainer) return;
      
      const deltaX = e.clientX - resizeStartX;
      const deltaY = e.clientY - resizeStartY;
      
      if (resizeDirection === 'right' || resizeDirection === 'corner') {
        const newWidth = Math.max(280, Math.min(700, resizeStartWidth + deltaX));
        demoChatContainer.style.width = newWidth + 'px';
      }
      
      if (resizeDirection === 'left') {
        const newWidth = Math.max(280, Math.min(700, resizeStartWidth - deltaX));
        if (newWidth > 280 && newWidth < 700) {
          demoChatContainer.style.width = newWidth + 'px';
          demoChatContainer.style.left = (resizeStartLeft + deltaX) + 'px';
          demoChatContainer.style.right = 'auto';
        }
      }
      
      if (resizeDirection === 'bottom' || resizeDirection === 'corner') {
        const newHeight = Math.max(250, resizeStartHeight + deltaY);
        demoChatContainer.style.height = newHeight + 'px';
      }
      
      if (resizeDirection === 'top') {
        const newHeight = Math.max(250, resizeStartHeight - deltaY);
        if (newHeight > 250) {
          demoChatContainer.style.height = newHeight + 'px';
          demoChatContainer.style.top = (resizeStartTop + deltaY) + 'px';
          demoChatContainer.style.bottom = 'auto';
        }
      }
    });
    
    document.addEventListener('mouseup', function() {
      if (isResizing) {
        isResizing = false;
        resizeDirection = null;
      }
    });
    
    // Open Chat button event listeners (panel buttons)
    const openChatBtnPanel2 = document.getElementById('openChatBtnPanel2');
    const tryMoreDemosBtn2 = document.getElementById('tryMoreDemosBtn2');
    if (openChatBtnPanel2) openChatBtnPanel2.addEventListener('click', openChat);
    if (tryMoreDemosBtn2) tryMoreDemosBtn2.addEventListener('click', openChat);
    
    
    // --------------------------------------------------
    // REVIT/GIF PANEL EXPAND/MINIMIZE (Green/Yellow buttons)
    // --------------------------------------------------
    // Shared state for expanded panel drag (single document listeners)
    let expandedDragState = null; // { box, wrapper, maxBtn, titlebar, offsetX, offsetY, dockZone, animateToWrapper }
    
    // Helper to create animateToWrapper function for a specific box
    // Works for both 'expanded' (green button) and 'free-floating' (dragged out) states
    function createAnimateToWrapper(revitBox, wrapper, maxBtn) {
      return function() {
        if (!wrapper) {
          revitBox.style.transition = '';
          revitBox.style.position = '';
          revitBox.style.top = '';
          revitBox.style.left = '';
          revitBox.style.right = '';
          revitBox.style.width = '';
          revitBox.style.height = '';
          revitBox.style.zIndex = '';
          revitBox.classList.remove('expanded');
          revitBox.classList.remove('free-floating');
          revitBox.classList.remove('snapping-back');
          if (maxBtn) { maxBtn.disabled = false; maxBtn.style.opacity = ''; maxBtn.style.cursor = ''; }
          return;
        }
        
        const currentRect = revitBox.getBoundingClientRect();
        const targetRect = wrapper.getBoundingClientRect();
        const zoom = parseFloat(getComputedStyle(document.body).zoom) || 1;
        
        revitBox.style.transition = 'none';
        revitBox.style.position = 'fixed';
        revitBox.style.top = (currentRect.top / zoom) + 'px';
        revitBox.style.left = (currentRect.left / zoom) + 'px';
        revitBox.style.width = (currentRect.width / zoom) + 'px';
        revitBox.style.height = (currentRect.height / zoom) + 'px';
        revitBox.style.zIndex = '1000';
        
        void revitBox.offsetHeight;
        
        revitBox.style.transition = 'top 0.35s cubic-bezier(0.4, 0, 0.2, 1), left 0.35s cubic-bezier(0.4, 0, 0.2, 1), width 0.35s cubic-bezier(0.4, 0, 0.2, 1), height 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
        revitBox.style.top = (targetRect.top / zoom) + 'px';
        revitBox.style.left = (targetRect.left / zoom) + 'px';
        revitBox.style.width = (targetRect.width / zoom) + 'px';
        revitBox.style.height = (targetRect.height / zoom) + 'px';
        
        setTimeout(() => {
          revitBox.style.transition = '';
          revitBox.style.position = '';
          revitBox.style.top = '';
          revitBox.style.left = '';
          revitBox.style.right = '';
          revitBox.style.width = '';
          revitBox.style.height = '';
          revitBox.style.zIndex = '';
          revitBox.classList.remove('expanded');
          revitBox.classList.remove('free-floating');
          revitBox.classList.remove('snapping-back');
          if (maxBtn) { maxBtn.disabled = false; maxBtn.style.opacity = ''; maxBtn.style.cursor = ''; }
        }, 350);
      };
    }
    
    // Initialize each revit box
    document.querySelectorAll('.demo-view-overlay .demo-revit-box').forEach(revitBox => {
      const titlebar = revitBox.querySelector('.demo-revit-titlebar');
      const maxBtn = revitBox.querySelector('.demo-titlebar-btn.max');
      const minBtn = revitBox.querySelector('.demo-titlebar-btn.min');
      const wrapper = revitBox.closest('.demo-revit-wrapper');
      const animateToWrapper = createAnimateToWrapper(revitBox, wrapper, maxBtn);
      
      // GREEN BUTTON: Expand panel (disabled when already expanded or free-floating)
      if (maxBtn) {
        maxBtn.addEventListener('mousedown', e => e.stopPropagation());
        maxBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          e.preventDefault();
          // Prevent if already expanded, free-floating (dragged out), or disabled
          if (revitBox.classList.contains('expanded') || revitBox.classList.contains('free-floating') || maxBtn.disabled) return;
          
          maxBtn.disabled = true;
          maxBtn.style.opacity = '0.5';
          maxBtn.style.cursor = 'not-allowed';
          
          const startRect = revitBox.getBoundingClientRect();
          const isReversed = revitBox.closest('.demo-split-view.reversed') !== null;
          
          // Calculate width based on poster image's actual aspect ratio
          // Use content area height (excluding titlebar) for accurate calculation
          const poster = revitBox.querySelector('.video-poster');
          const contentArea = revitBox.querySelector('.demo-revit-content');
          const contentHeight = contentArea ? contentArea.getBoundingClientRect().height : startRect.height;
          const aspectRatio = (poster && poster.naturalWidth && poster.naturalHeight) 
            ? poster.naturalWidth / poster.naturalHeight 
            : 16 / 9; // Fallback
          const endWidth = contentHeight * aspectRatio;
          const endLeft = isReversed ? startRect.left : startRect.right - endWidth;
          
          const zoom = parseFloat(getComputedStyle(document.body).zoom) || 1;
          revitBox.style.transition = 'none';
          revitBox.style.position = 'fixed';
          revitBox.style.top = (startRect.top / zoom) + 'px';
          revitBox.style.left = (startRect.left / zoom) + 'px';
          revitBox.style.width = (startRect.width / zoom) + 'px';
          revitBox.style.height = (startRect.height / zoom) + 'px';
          revitBox.style.zIndex = '1000';
          revitBox.classList.add('expanded');
          
          void revitBox.offsetHeight;
          
          revitBox.style.transition = 'left 0.35s cubic-bezier(0.4, 0, 0.2, 1), width 0.35s cubic-bezier(0.4, 0, 0.2, 1)';
          revitBox.style.left = (endLeft / zoom) + 'px';
          revitBox.style.width = (endWidth / zoom) + 'px';
        });
      }
      
      // YELLOW BUTTON: Minimize (works for both expanded AND free-floating)
      if (minBtn) {
        minBtn.addEventListener('mousedown', e => e.stopPropagation());
        minBtn.addEventListener('click', function(e) {
          e.stopPropagation();
          e.preventDefault();
          // Work for either expanded (green button) or free-floating (dragged out)
          if (!revitBox.classList.contains('expanded') && !revitBox.classList.contains('free-floating')) return;
          animateToWrapper();
        });
      }
      
      // DRAG: Only when expanded
      if (titlebar) {
        titlebar.addEventListener('mousedown', function(e) {
          if (!revitBox.classList.contains('expanded')) return;
          if (e.target.closest('.demo-titlebar-btn')) return;
          
          e.preventDefault();
          e.stopPropagation();
          
          revitBox.style.transition = 'none';
          const rect = revitBox.getBoundingClientRect();
          const zoom = parseFloat(getComputedStyle(document.body).zoom) || 1;
          revitBox.style.left = (rect.left / zoom) + 'px';
          revitBox.style.right = 'auto';
          
          let dockZone = null;
          if (wrapper) {
            dockZone = document.createElement('div');
            dockZone.className = 'revit-dock-zone';
            dockZone.style.cssText = 'position:absolute;top:0;left:0;right:0;bottom:0;border:2px dashed #4a9eff;border-radius:10px;background:rgba(74,158,255,0.1);z-index:1;pointer-events:none;';
            wrapper.style.position = 'relative';
            wrapper.appendChild(dockZone);
          }
          
          expandedDragState = {
            box: revitBox,
            wrapper: wrapper,
            maxBtn: maxBtn,
            titlebar: titlebar,
            offsetX: e.clientX - rect.left,
            offsetY: e.clientY - rect.top,
            dockZone: dockZone,
            animateToWrapper: animateToWrapper
          };
          
          document.body.style.userSelect = 'none';
        });
      }
    });
    
    // Single document mousemove for expanded panel drag
    document.addEventListener('mousemove', function(e) {
      if (!expandedDragState) return;
      const { box, offsetX, offsetY, dockZone } = expandedDragState;
      const zoom = parseFloat(getComputedStyle(document.body).zoom) || 1;
      
      box.style.left = ((e.clientX - offsetX) / zoom) + 'px';
      box.style.top = ((e.clientY - offsetY) / zoom) + 'px';
      
      if (dockZone) {
        const dockRect = dockZone.getBoundingClientRect();
        const isOverDock = e.clientX >= dockRect.left && e.clientX <= dockRect.right &&
                           e.clientY >= dockRect.top && e.clientY <= dockRect.bottom;
        dockZone.style.background = isOverDock ? 'rgba(74,158,255,0.3)' : 'rgba(74,158,255,0.1)';
      }
    });
    
    // Single document mouseup for expanded panel drag
    document.addEventListener('mouseup', function(e) {
      if (!expandedDragState) return;
      const { titlebar, dockZone, animateToWrapper } = expandedDragState;
      
      document.body.style.userSelect = '';
      
      if (dockZone) {
        const dockRect = dockZone.getBoundingClientRect();
        const isOverDock = e.clientX >= dockRect.left && e.clientX <= dockRect.right &&
                           e.clientY >= dockRect.top && e.clientY <= dockRect.bottom;
        dockZone.remove();
        if (isOverDock) animateToWrapper();
      }
      
      expandedDragState = null;
    });
    
    // --------------------------------------------------
    // CHAT SCROLL CONTAINMENT
    // --------------------------------------------------
    // Prevent page scroll when scrolling inside chat message containers
    document.querySelectorAll('.demo-chat-messages').forEach(container => {
      container.addEventListener('wheel', function(e) {
        const atTop = container.scrollTop === 0;
        const atBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 1;
        
        // If scrolling up at top or down at bottom, prevent page scroll
        if ((e.deltaY < 0 && atTop) || (e.deltaY > 0 && atBottom)) {
          e.preventDefault();
        }
        
        // Always stop propagation to prevent view navigation
        e.stopPropagation();
      }, { passive: false });
    });
    
    // Prevent page scroll when scrolling inside chat history sidebar
    document.querySelectorAll('.demo-history-list').forEach(container => {
      container.addEventListener('wheel', function(e) {
        const atTop = container.scrollTop === 0;
        const atBottom = container.scrollHeight - container.scrollTop <= container.clientHeight + 1;
        
        // If scrolling up at top or down at bottom, prevent page scroll
        if ((e.deltaY < 0 && atTop) || (e.deltaY > 0 && atBottom)) {
          e.preventDefault();
        }
        
        // Always stop propagation to prevent view navigation
        e.stopPropagation();
      }, { passive: false });
    });
    
    // Prevent page scroll when scrolling inside BUILD X ribbon panels
    document.querySelectorAll('.buildx-ribbon-panel').forEach(panel => {
      panel.addEventListener('wheel', function(e) {
        const atTop = panel.scrollTop === 0;
        const atBottom = panel.scrollHeight - panel.scrollTop <= panel.clientHeight + 1;
        
        // Only stop propagation if we can scroll within the panel
        if (!((e.deltaY < 0 && atTop) || (e.deltaY > 0 && atBottom))) {
          e.stopPropagation();
        }
      }, { passive: true });
    });
    
    // Allow wheel events from buildx center area to propagate for view navigation
    const buildxCenterArea = document.querySelector('.buildx-center-area');
    if (buildxCenterArea) {
      // Center area should not block wheel events - let them bubble to document
      // (default behavior, no stopPropagation needed)
    }
    
    // --------------------------------------------------
    // VIEW 4: Floorplan MEP Chat Functionality
    // Now handled by js/view4-chat.js for better separation
    // --------------------------------------------------
    
    // NOTE: All View 4 chat functionality (conversations, thinking steps,
    // neural node animation, history switching) moved to js/view4-chat.js
    // to reduce file size and improve separation of concerns.
    
    // View 5 buttons are below this comment
    
    // (View 4 conversation data and functions removed - see js/view4-chat.js)
    
    // START OF REMOVED SECTION - kept for reference
    /* 
