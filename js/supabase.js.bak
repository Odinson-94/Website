  // ============================================
  // GEOLOCATION - Get user's country
  // ============================================
  async function getUserCountry() {
    try {
      // Use ip-api.com (free, no API key needed)
      const response = await fetch('http://ip-api.com/json/?fields=countryCode,country');
      if (response.ok) {
        const data = await response.json();
        return {
          country_code: data.countryCode,
          country_name: data.country
        };
      }
    } catch (err) {
      console.log('Could not detect location, using default');
    }
    // Fallback
    return { country_code: 'XX', country_name: 'Unknown' };
  }

  // ============================================
  // SIGNUP FUNCTIONS
  // ============================================
  
  async function submitSignup(email, name, company, signupType, countryCode, countryName) {
    try {
      const response = await fetch(`${SUPABASE_URL}/rest/v1/signups`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'Prefer': 'return=minimal'
        },
        body: JSON.stringify({
          email: email,
          name: name || null,
          company: company || null,
          country_code: countryCode,
          country_name: countryName,
          signup_type: signupType // 'early_access' or 'news'
        })
      });

      if (response.ok) {
        return { success: true };
      } else if (response.status === 409) {
        return { success: false, error: 'This email is already registered!' };
      } else {
        const errorData = await response.json();
        return { success: false, error: errorData.message || 'Signup failed. Please try again.' };
      }
    } catch (err) {
      console.error('Signup error:', err);
      return { success: false, error: 'Network error. Please try again.' };
    }
  }

  // ============================================
  // GET SIGNUP COUNTS BY COUNTRY (for map)
  // ============================================
  async function getSignupCountsByCountry() {
    try {
      const response = await fetch(
        `${SUPABASE_URL}/rest/v1/signup_counts_by_country?select=*`,
        {
          headers: {
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
          }
        }
      );
      
      if (response.ok) {
        return await response.json();
      }
    } catch (err) {
      console.error('Error fetching signup counts:', err);
    }
    return [];
  }

