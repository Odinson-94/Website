{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adelphos://page-type/agentic-service",
  "title": "Agentic Service Page",
  "description": "Schema for one entry in sandbox/data/agentic-services.json (services[] item).",
  "type": "object",
  "required": [
    "slug", "title", "headline_claim", "tagline", "key_outcomes",
    "detail_paragraph", "blurb", "the_shift", "features",
    "what_we_offer", "how_it_becomes_agentic", "engagement", "icon", "seo"
  ],
  "properties": {
    "slug":            { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title":           { "type": "string", "minLength": 2, "maxLength": 60 },
    "is_flagship":     { "type": "boolean" },
    "headline_claim":  { "type": "string", "minLength": 30, "maxLength": 220 },
    "tagline":         { "type": "string", "minLength": 30, "maxLength": 320 },
    "key_outcomes":    { "type": "array", "minItems": 3, "maxItems": 4 },
    "detail_paragraph":{ "type": "string", "minLength": 400, "maxLength": 1500 },
    "blurb":           { "type": "string", "minLength": 60,  "maxLength": 600 },
    "the_shift": {
      "type": "object",
      "required": ["before", "after"],
      "properties": {
        "before": { "type": "string", "minLength": 30, "maxLength": 400 },
        "after":  { "type": "string", "minLength": 30, "maxLength": 400 }
      }
    },
    "features": {
      "type": "array", "minItems": 5, "maxItems": 15,
      "items": {
        "type": "object", "required": ["name", "desc"],
        "properties": { "name": { "type": "string" }, "desc": { "type": "string" } }
      }
    },
    "what_we_offer":           { "type": "array", "minItems": 3, "maxItems": 8, "items": { "type": "string" } },
    "how_it_becomes_agentic":  { "type": "array", "minItems": 4, "maxItems": 6, "items": { "type": "string" } },
    "engagement":              { "type": "string", "minLength": 20, "maxLength": 200 },
    "icon":                    { "type": "string" },
    "seo": {
      "type": "object",
      "required": ["why_h3", "shift_h3", "special_h3", "who_h3"],
      "properties": {
        "why_h3":     { "type": "string", "maxLength": 120 },
        "shift_h3":   { "type": "string", "maxLength": 120 },
        "special_h3": { "type": "string", "maxLength": 120 },
        "who_h3":     { "type": "string", "maxLength": 120 }
      }
    }
  }
}
