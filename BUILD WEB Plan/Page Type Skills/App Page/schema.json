{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adelphos://page-type/app",
  "title": "App Page",
  "description": "Schema for one entry in sandbox/data/apps.json (apps[] item).",
  "type": "object",
  "required": [
    "slug", "title", "headline_claim", "tagline", "surface", "status",
    "icon", "key_outcomes", "detail_paragraph", "the_shift", "blurb",
    "best_for", "primary_cta", "secondary_cta", "seo"
  ],
  "properties": {
    "slug":            { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "title":           { "type": "string", "minLength": 2, "maxLength": 60 },
    "is_flagship":     { "type": "boolean" },
    "headline_claim":  { "type": "string", "minLength": 30, "maxLength": 200 },
    "tagline":         { "type": "string", "minLength": 30, "maxLength": 280 },
    "surface":         { "type": "string", "minLength": 5,  "maxLength": 120 },
    "status":          { "enum": ["live", "coming-soon"] },
    "icon":            { "type": "string" },
    "key_outcomes": {
      "type": "array", "minItems": 3, "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["stat", "label"],
        "properties": {
          "stat":  { "type": "string", "maxLength": 20 },
          "label": { "type": "string", "maxLength": 80 }
        }
      }
    },
    "detail_paragraph": {
      "type": "string", "minLength": 400, "maxLength": 1500,
      "description": "80–180 words. Must contain a quantified time-saving claim."
    },
    "blurb":            { "type": "string", "minLength": 60, "maxLength": 600 },
    "the_shift": {
      "type": "object",
      "required": ["before", "after"],
      "properties": {
        "before": { "type": "string", "minLength": 30, "maxLength": 400 },
        "after":  { "type": "string", "minLength": 30, "maxLength": 400 }
      }
    },
    "features": {
      "type": "array", "minItems": 5, "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["name", "desc"],
        "properties": {
          "name": { "type": "string", "maxLength": 60 },
          "desc": { "type": "string", "maxLength": 200 }
        }
      }
    },
    "feature_groups": {
      "type": "array", "minItems": 2, "maxItems": 8,
      "items": {
        "type": "object",
        "required": ["title", "features"],
        "properties": {
          "title":    { "type": "string", "maxLength": 60 },
          "features": { "type": "array", "minItems": 3, "maxItems": 12 }
        }
      }
    },
    "what_makes_it_special": { "type": "string", "description": "Legacy field — kept for back-compat, not rendered." },
    "best_for":              { "type": "array", "minItems": 3, "maxItems": 5, "items": { "type": "string" } },
    "hero_video":            { "type": "string" },
    "primary_cta": {
      "type": "object",
      "required": ["label", "href"],
      "properties": {
        "label": { "type": "string", "pattern": "^(Download|Run|Open|Get|Install).*", "maxLength": 60,
                   "description": "Self-serve verb only — no 'Talk to us', no 'Book a walkthrough'." },
        "href":  { "type": "string" }
      }
    },
    "secondary_cta": {
      "type": "object",
      "required": ["label", "href"],
      "properties": { "label": { "type": "string", "maxLength": 60 }, "href": { "type": "string" } }
    },
    "seo": {
      "type": "object",
      "required": ["why_h3", "shift_h3", "special_h3", "who_h3"],
      "properties": {
        "why_h3":     { "type": "string", "maxLength": 120 },
        "shift_h3":   { "type": "string", "maxLength": 120 },
        "special_h3": { "type": "string", "maxLength": 120 },
        "who_h3":     { "type": "string", "maxLength": 120 }
      }
    }
  },
  "oneOf": [
    { "required": ["features"] },
    { "required": ["feature_groups"] }
  ]
}
